@page "/reports"
@namespace smartLaywer.Components.Pages
@inject IReportService ReportService
@using smartLaywer.DTOs.Report

<PageTitle>التقارير والإحصائيات</PageTitle>

<div class="reports-page" dir="rtl">

    <div class="page-header-row">
        <div>
            <h1 class="page-title">التقارير والإحصائيات</h1>
            <p class="page-sub">عرض وتحليل البيانات والإحصائيات الحقيقية للنظام</p>
        </div>
        <div class="btn-group">
            <button class="btn-outline" @onclick="ExportPDF">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                تصدير PDF
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>جاري جلب البيانات وتحليل الإحصائيات...</p>
        </div>
    }
    else
    {
        <div class="stats-grid">
            @foreach (var s in statsCards)
            {
                <div class="stat-card">
                    <div class="stat-body">
                        <div>
                            <p class="stat-label">@s.Label</p>
                            <h3 class="stat-value">@s.Value</h3>
                            <p class="stat-trend">@s.Trend</p>
                        </div>
                        <div class="stat-icon @s.BgClass">
                            @((MarkupString)s.Icon)
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="card">
            <div class="card-body">
                <div class="tabs">
                    @foreach (var tab in tabs)
                    {
                        <button class="tab @(activeTab == tab.Key ? "tab-active" : "")"
                                @onclick="() => activeTab = tab.Key">
                            @tab.Label
                        </button>
                    }
                </div>

                @if (activeTab == "monthly")
                {
                    <div class="chart-section">
                        <h3 class="chart-title">معدل نمو القضايا والجلسات (آخر 6 أشهر)</h3>
                        <div class="bar-chart">
                            @foreach (var item in monthlyData)
                            {
                                <div class="bar-group">
                                    <div class="bars-wrap">
                                        @* ضرب القيم في 5 لتمثيل الطول بصرياً بشكل أفضل *@
                                        <div class="bar bar-amber" style="height:@(item.Cases * 10 + 5)px" title="قضايا: @item.Cases"></div>
                                        <div class="bar bar-blue" style="height:@(item.Hearings * 10 + 5)px" title="جلسات: @item.Hearings"></div>
                                    </div>
                                    <p class="bar-label">@item.Month</p>
                                </div>
                            }
                        </div>
                        <div class="chart-legend">
                            <div class="leg-item"><span class="leg-dot dot-amber"></span> القضايا</div>
                            <div class="leg-item"><span class="leg-dot dot-blue"></span> الجلسات</div>
                        </div>
                    </div>
                }
                else if (activeTab == "types")
                {
                    <div class="chart-section">
                        <h3 class="chart-title">توزيع القضايا حسب النوع</h3>
                        <div class="status-bars">
                            @foreach (var t in caseTypeData)
                            {
                                <div class="status-row">
                                    <span class="status-name" style="width: 100px;">@t.Name</span>
                                    <div class="status-bar-wrap">
                                        <div class="status-bar" style="width: @(CalculatePercent(t.Value))%; background: @t.Color;"></div>
                                    </div>
                                    <span class="status-val">@t.Value</span>
                                </div>
                            }
                        </div>
                    </div>
                }
                else if (activeTab == "status")
                {
                    <div class="chart-section">
                        <h3 class="chart-title">حالات القضايا الحالية</h3>
                        <div class="status-bars">
                            @foreach (var s in caseStatusData)
                            {
                                <div class="status-row">
                                    <span class="status-name" style="width: 100px;">@s.Name</span>
                                    <div class="status-bar-wrap">
                                        <div class="status-bar" style="width: @(CalculatePercent(s.Value))%; background: #2563eb;"></div>
                                    </div>
                                    <span class="status-val">@s.Value</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(toastMsg))
    {
        <div class="toast-container">
            <div class="toast">@toastMsg</div>
        </div>
    }
</div>

<style>
    /* تم الاحتفاظ بجميع الستايلات الخاصة بك مع تحسينات بسيطة للتجاوب */
    .reports-page {
        padding: 1.5rem;
        font-family: 'Segoe UI', Tahoma, sans-serif;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .page-header-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: .75rem;
    }

    .page-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1e293b;
        margin: 0;
    }

    .page-sub {
        color: #64748b;
        margin: .25rem 0 0;
    }

    .loading-state {
        text-align: center;
        padding: 3rem;
        color: #64748b;
    }

    .spinner {
        border: 4px solid #f3f3f3;
        border-top: 4px solid #d97706;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        animation: spin 1s linear infinite;
        margin: 0 auto 1rem;
    }
    @@keyframes spin {
        0%

    {
        transform: rotate(0deg);
    }

    100% {
        transform: rotate(360deg);
    }

    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1rem;
    }

    .stat-card {
        background: #fff;
        border-radius: 12px;
        padding: 1.25rem;
        box-shadow: 0 1px 6px rgba(0,0,0,.08);
    }

    .stat-body {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .stat-label {
        font-size: .85rem;
        color: #64748b;
        margin: 0;
    }

    .stat-value {
        font-size: 1.9rem;
        font-weight: 700;
        color: #1e293b;
        margin: .2rem 0;
    }

    .stat-trend {
        font-size: .78rem;
        color: #16a34a;
        margin: 0;
    }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
    }

    .bg-blue {
        background: #2563eb;
    }

    .card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 1px 6px rgba(0,0,0,.08);
    }

    .card-body {
        padding: 1.5rem;
    }

    .tabs {
        display: flex;
        gap: .25rem;
        background: #f8fafc;
        border-radius: 10px;
        padding: .3rem;
        margin-bottom: 1.25rem;
        width: fit-content;
    }

    .tab {
        padding: .45rem 1.25rem;
        border: none;
        background: transparent;
        border-radius: 8px;
        font-size: .85rem;
        cursor: pointer;
        color: #64748b;
        transition: all .2s;
    }

    .tab-active {
        background: #fff;
        color: #d97706;
        font-weight: 600;
        box-shadow: 0 1px 4px rgba(0,0,0,.08);
    }

    .bar-chart {
        display: flex;
        align-items: flex-end;
        gap: 1.5rem;
        height: 200px;
        padding-bottom: .5rem;
        border-bottom: 2px solid #f1f5f9;
        margin-top: 1rem;
    }

    .bar-group {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex: 1;
    }

    .bars-wrap {
        display: flex;
        align-items: flex-end;
        gap: .4rem;
    }

    .bar {
        width: 25px;
        border-radius: 4px 4px 0 0;
        transition: all .3s;
    }

    .bar-amber {
        background: #d97706;
    }

    .bar-blue {
        background: #2563eb;
    }

    .bar-label {
        font-size: .75rem;
        margin-top: .5rem;
        color: #64748b;
    }

    .chart-legend {
        display: flex;
        gap: 1.5rem;
        margin-top: 1rem;
    }

    .leg-item {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .85rem;
    }

    .leg-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .dot-amber {
        background: #d97706;
    }

    .dot-blue {
        background: #2563eb;
    }

    .status-bars {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .status-row {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .status-bar-wrap {
        flex: 1;
        background: #f1f5f9;
        height: 12px;
        border-radius: 10px;
    }

    .status-bar {
        height: 100%;
        border-radius: 10px;
    }

    .toast-container {
        position: fixed;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1000;
    }

    .toast {
        background: #1e293b;
        color: #fff;
        padding: .75rem 1.5rem;
        border-radius: 10px;
        box-shadow: 0 4px 12px rgba(0,0,0,.15);
    }

    .btn-outline {
        background: #fff;
        border: 1px solid #e2e8f0;
        padding: .5rem 1rem;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .5rem;
    }
</style>

@code {
    private bool isLoading = true;
    private string activeTab = "monthly";
    private string toastMsg = "";
    private ReportDashboardDto dashboardData;

    private List<StatInfo> statsCards = new();
    private List<MonthData> monthlyData = new();
    private List<TypeData> caseTypeData = new();
    private List<StatusData> caseStatusData = new();

    private List<TabItem> tabs = new()
    {
        new("monthly", "الإحصائيات الشهرية"),
        new("types", "أنواع القضايا"),
        new("status", "حالات القضايا")
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            dashboardData = await ReportService.GetReportDashboardAsync();

            if (dashboardData != null)
            {
                statsCards = dashboardData.Stats.Select(s => new StatInfo(s.Label, s.Value, s.Trend, "bg-blue", IconBriefcase)).ToList();
                monthlyData = dashboardData.Monthly.Select(m => new MonthData(m.Month, m.Cases, m.Hearings)).ToList();
                caseTypeData = dashboardData.CaseTypes.Select(t => new TypeData(t.Name, t.Value, GetRandomColor())).ToList();
                caseStatusData = dashboardData.CaseStatuses.Select(s => new StatusData(s.Name, s.Value, "#2563eb")).ToList();
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private int CalculatePercent(int value)
    {
        int max = 1;
        if (activeTab == "types" && caseTypeData.Any()) max = caseTypeData.Max(x => x.Value);
        if (activeTab == "status" && caseStatusData.Any()) max = caseStatusData.Max(x => x.Value);
        return (value * 100) / (max == 0 ? 1 : max);
    }

    private string GetRandomColor()
    {
        string[] colors = { "#3b82f6", "#10b981", "#f59e0b", "#ef4444", "#8b5cf6", "#ec4899" };
        return colors[new Random().Next(colors.Length)];
    }

    private async Task ExportPDF()
    {
        toastMsg = "جاري تحضير ملف PDF للتحميل...";
        StateHasChanged();
        await Task.Delay(2000);
        toastMsg = "";
    }

    private record StatInfo(string Label, string Value, string Trend, string BgClass, string Icon);
    private record MonthData(string Month, int Cases, int Hearings);
    private record TypeData(string Name, int Value, string Color);
    private record StatusData(string Name, int Value, string Color);
    private record TabItem(string Key, string Label);

    private const string IconBriefcase = """<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>""";
}