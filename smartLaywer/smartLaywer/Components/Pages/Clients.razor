@page "/clients"
@namespace smartLaywer.Components.Pages
@using smartLaywer.DTO.Clients
@using smartLaywer.Services.ClassService
@using smartLaywer.Models
@using smartLaywer.Enum
@inject IClientService ClientService
@inject NavigationManager Navigation

<PageTitle>إدارة العملاء - نظام إدارة القضايا</PageTitle>

<div class="clients-page" dir="rtl">

    <!-- Header -->
    <div class="page-header-row">
        <div>
            <h1 class="page-title">إدارة العملاء</h1>
            <p class="page-sub">عرض وإدارة جميع العملاء</p>
        </div>
        <button class="btn-primary" @onclick='() => Navigation.NavigateTo("/cases")'>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            إضافة عميل جديد
        </button>
    </div>

    <!-- Search + Stats -->
    <div class="top-bar">
        <div class="search-box">
            <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
            <input class="search-input" placeholder="ابحث عن عميل (الاسم، الهاتف، البريد)"
                   @bind="searchTerm" @bind:event="oninput" />
        </div>
        <div class="mini-stat">
            <p class="mini-label">إجمالي العملاء</p>
            <p class="mini-value">@allClients.Count</p>
        </div>
        <div class="mini-stat">
            <p class="mini-label">عملاء نشطين</p>
            <p class="mini-value green">@allClients.Count(c => c.IsActive)</p>
        </div>
    </div>

    <!-- Loading -->
    @if (isLoading)
    {
        <div class="loading-msg">جاري التحميل...</div>
    }

    @if (!string.IsNullOrEmpty(loadError))
    {
        <div class="error-msg" @onclick="() => loadError = string.Empty" style="cursor:pointer">
            ⚠️ @loadError &nbsp;<small>(اضغط للإغلاق)</small>
        </div>
    }

    @if (!isLoading)
    {
        <!-- Table -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">قائمة العملاء (@FilteredClients.Count())</h2>
            </div>
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>الاسم</th>
                            <th>نوع العميل</th>
                            <th>الهاتف</th>
                            <th>البريد الإلكتروني</th>
                            <th>العنوان</th>
                            <th>القضايا النشطة</th>
                            <th>الحالة</th>
                            <th>تاريخ الإضافة</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!FilteredClients.Any())
                        {
                            <tr>
                                <td colspan="9" class="empty-row">لا توجد نتائج</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var c in FilteredClients)
                            {
                                <tr>
                                    <td class="fw-600">@c.FullName</td>
                                    <td>
                                        <span class="badge badge-purple">@c.ClientType</span>
                                    </td>
                                    <td>
                                        <span class="cell-icon-text">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24"
                                                 fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.79 19.79 0 0 1 11.61 19a19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 3.09 4.18 2 2 0 0 1 5.07 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L9.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 23 17z" />
                                            </svg>
                                            @c.Phone
                                            @if (!string.IsNullOrEmpty(c.SecondaryPhone))
                                            {
                                                <span class="secondary-phone"> / @c.SecondaryPhone</span>
                                            }
                                        </span>
                                    </td>
                                    <td>
                                        <span class="cell-icon-text">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24"
                                                 fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                                                <polyline points="22,6 12,13 2,6" />
                                            </svg>
                                            @(string.IsNullOrEmpty(c.Email) ? "-" : c.Email)
                                        </span>
                                    </td>
                                    <td>@c.Address</td>
                                    <td>
                                        <span class="badge @(c.ActiveCasesCount > 0 ? "badge-blue" : "badge-gray")">
                                            @c.ActiveCasesCount
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @(c.IsActive ? "badge-green" : "badge-gray")">
                                            @(c.IsActive ? "نشط" : "غير نشط")
                                        </span>
                                    </td>
                                    <td class="date-cell">@c.CreatedAt.ToString("yyyy/MM/dd")</td>
                                    <td>
                                        <div class="action-btns">
                                            <button class="icon-btn" title="عرض التفاصيل" @onclick="() => OpenViewDialog(c)">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                                     fill="none" stroke="currentColor" stroke-width="2">
                                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                                    <circle cx="12" cy="12" r="3" />
                                                </svg>
                                            </button>
                                            <button class="icon-btn" title="تعديل" @onclick="() => OpenEditDialog(c.Id)">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                                     fill="none" stroke="currentColor" stroke-width="2">
                                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                                </svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@* <!-- ─── Add Client Dialog ─── -->
@if (showAddDialog)
{
    <div class="dialog-overlay" @onclick="CloseAddDialog">
        <div class="dialog dialog-lg" @onclick:stopPropagation="true" dir="rtl">
            <div class="dialog-header">
                <h3>إضافة عميل جديد</h3>
                <button class="dialog-close" @onclick="CloseAddDialog">✕</button>
            </div>
            <p class="dialog-sub">أدخل بيانات العميل الجديد</p>

            <div class="form-grid">
                <div class="form-group">
                    <label>الاسم الكامل *</label>
                    <input class="form-input" @bind="addModel.FullName" placeholder="أدخل الاسم الكامل" />
                </div>
                <div class="form-group">
                    <label>نوع العميل</label>
                    <select class="form-input" @bind="addModel.ClientType">
                        <option value="@ClientTypeEnum.Individual">فرد</option>
                        <option value="@ClientTypeEnum.Company">شركة</option>
                        <option value="@ClientTypeEnum.Government">جهة حكومية</option>
                        <option value="@ClientTypeEnum.Other">أخرى</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>رقم الهاتف *</label>
                    <input class="form-input" @bind="addModel.Phone" placeholder="01xxxxxxxxx" dir="ltr" />
                </div>
                <div class="form-group">
                    <label>رقم هاتف بديل</label>
                    <input class="form-input" @bind="addModel.SecondaryPhone" placeholder="01xxxxxxxxx" dir="ltr" />
                </div>
                <div class="form-group">
                    <label>البريد الإلكتروني</label>
                    <input class="form-input" @bind="addModel.Email" type="email" placeholder="example@email.com" dir="ltr" />
                </div>
                <div class="form-group">
                    <label>الرقم القومي / السجل التجاري</label>
                    <input class="form-input" @bind="addModel.NationalId" placeholder="29012011234567" dir="ltr" />
                </div>
                <div class="form-group">
                    <label>المسمى الوظيفي</label>
                    <input class="form-input" @bind="addModel.JobTitle" placeholder="مهندس، محاسب..." />
                </div>
                <div class="form-group">
                    <label>الجنس</label>
                    <select class="form-input" @bind="addModel.Gender">
                        <option value="">-- اختر --</option>
                        <option value="ذكر">ذكر</option>
                        <option value="أنثى">أنثى</option>
                    </select>
                </div>
                <div class="form-group form-full">
                    <label>العنوان *</label>
                    <input class="form-input" @bind="addModel.Address" placeholder="أدخل العنوان الكامل" />
                </div>
            </div>

            @if (!string.IsNullOrEmpty(addError))
            {
                <p class="form-error">@addError</p>
            }

            <div class="dialog-actions">
                <button class="btn-primary" disabled="@isSaving" @onclick="HandleAddClient">
                    @(isSaving ? "جاري الحفظ..." : "حفظ العميل")
                </button>
                <button class="btn-outline" @onclick="CloseAddDialog">إلغاء</button>
            </div>
        </div>
    </div>
} *@

<!-- ─── View Client Dialog ─── -->
@if (showViewDialog && viewClient is not null)
{
    <div class="dialog-overlay" @onclick="() => showViewDialog = false">
        <div class="dialog dialog-lg" @onclick:stopPropagation="true" dir="rtl">
            <div class="dialog-header">
                <h3>بيانات العميل</h3>
                <button class="dialog-close" @onclick="() => showViewDialog = false">✕</button>
            </div>

            <div class="view-grid">
                <div class="view-item">
                    <span class="view-label">الاسم الكامل</span>
                    <span class="view-value fw-600">@viewClient.FullName</span>
                </div>
                <div class="view-item">
                    <span class="view-label">نوع العميل</span>
                    <span class="view-value">
                        <span class="badge badge-purple">@viewClient.ClientType</span>
                    </span>
                </div>
                <div class="view-item">
                    <span class="view-label">الهاتف الرئيسي</span>
                    <span class="view-value" dir="ltr">@viewClient.Phone</span>
                </div>
                <div class="view-item">
                    <span class="view-label">الهاتف البديل</span>
                    <span class="view-value" dir="ltr">@(string.IsNullOrEmpty(viewClient.SecondaryPhone) ? "-" : viewClient.SecondaryPhone)</span>
                </div>
                <div class="view-item">
                    <span class="view-label">البريد الإلكتروني</span>
                    <span class="view-value" dir="ltr">@(string.IsNullOrEmpty(viewClient.Email) ? "-" : viewClient.Email)</span>
                </div>
                <div class="view-item">
                    <span class="view-label">القضايا النشطة</span>
                    <span class="view-value">
                        <span class="badge @(viewClient.ActiveCasesCount > 0 ? "badge-blue" : "badge-gray")">@viewClient.ActiveCasesCount</span>
                    </span>
                </div>
                <div class="view-item form-full">
                    <span class="view-label">العنوان</span>
                    <span class="view-value">@viewClient.Address</span>
                </div>
                <div class="view-item">
                    <span class="view-label">الحالة</span>
                    <span class="view-value">
                        <span class="badge @(viewClient.IsActive ? "badge-green" : "badge-gray")">@(viewClient.IsActive ? "نشط" : "غير نشط")</span>
                    </span>
                </div>
                <div class="view-item">
                    <span class="view-label">تاريخ الإضافة</span>
                    <span class="view-value">@viewClient.CreatedAt.ToString("yyyy/MM/dd")</span>
                </div>
            </div>

            <div class="dialog-actions" style="margin-top:1.25rem;">
                <button class="btn-primary" @onclick="() => { showViewDialog = false; OpenEditDialog(viewClient.Id); }">
                    تعديل البيانات
                </button>
                <button class="btn-outline" @onclick="() => showViewDialog = false">إغلاق</button>
            </div>
        </div>
    </div>
}

<!-- ─── Edit Client Dialog ─── -->
@if (showEditDialog && editModel is not null)
{
    <div class="dialog-overlay" @onclick="CloseEditDialog">
        <div class="dialog dialog-lg" @onclick:stopPropagation="true" dir="rtl">
            <div class="dialog-header">
                <h3>تعديل بيانات العميل</h3>
                <button class="dialog-close" @onclick="CloseEditDialog">✕</button>
            </div>
            <p class="dialog-sub">قم بتحديث بيانات العميل</p>

            <div class="form-grid">
                <div class="form-group">
                    <label>الاسم الكامل *</label>
                    <input class="form-input" @bind="editModel.FullName" placeholder="أدخل الاسم الكامل" />
                </div>
                <div class="form-group">
                    <label>الحالة</label>

                    <div class="toggle-switch">
                        <input type="checkbox" id="isActiveToggle" @bind="editModel.IsActive" />
                        <label for="isActiveToggle" class="toggle-label"></label>
                    </div>

                    <span class="toggle-text">
                        @(editModel.IsActive ? "نشط" : "غير نشط")
                    </span>
                </div>
                <div class="form-group">
                    <label>نوع العميل</label>
                    <select class="form-input" @bind="editModel.ClientType">
                        <option value="@ClientTypeEnum.Individual">فرد</option>
                        <option value="@ClientTypeEnum.Company">شركة</option>
                        <option value="@ClientTypeEnum.Government">جهة حكومية</option>
                        <option value="@ClientTypeEnum.Other">أخرى</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>رقم الهاتف *</label>
                    <input class="form-input" @bind="editModel.Phone" placeholder="01xxxxxxxxx" dir="ltr" />
                </div>
                <div class="form-group">
                    <label>رقم هاتف بديل</label>
                    <input class="form-input" @bind="editModel.SecondaryPhone" placeholder="01xxxxxxxxx" dir="ltr" />
                </div>
                <div class="form-group">
                    <label>البريد الإلكتروني</label>
                    <input class="form-input" @bind="editModel.Email" type="email" placeholder="example@email.com" dir="ltr" />
                </div>
                <div class="form-group">
                    <label>الرقم القومي / السجل التجاري</label>
                    <input class="form-input" @bind="editModel.NationalId" placeholder="29012011234567" dir="ltr" />
                </div>
                <div class="form-group">
                    <label>المسمى الوظيفي</label>
                    <input class="form-input" @bind="editModel.JobTitle" placeholder="مهندس، محاسب..." />
                </div>
                <div class="form-group">
                    <label>الجنس</label>
                    <select class="form-input" @bind="editModel.Gender">
                        <option value="">-- اختر --</option>
                        <option value="ذكر">ذكر</option>
                        <option value="أنثى">أنثى</option>
                    </select>
                </div>
                <div class="form-group form-full">
                    <label>العنوان *</label>
                    <input class="form-input" @bind="editModel.Address" placeholder="أدخل العنوان الكامل" />
                </div>
            </div>

            @if (!string.IsNullOrEmpty(editError))
            {
                <p class="form-error">@editError</p>
            }

            <div class="dialog-actions">
                <button class="btn-primary" disabled="@isSaving" @onclick="HandleEditClient">
                    @(isSaving ? "جاري الحفظ..." : "حفظ التعديلات")
                </button>
                <button class="btn-outline" @onclick="CloseEditDialog">إلغاء</button>
            </div>
        </div>
    </div>
}

<style>
    .clients-page {
        padding: 1.5rem;
        font-family: 'Segoe UI', Tahoma, sans-serif;
    }

    .page-header-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.25rem;
        flex-wrap: wrap;
        gap: .75rem;
    }

    .page-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1e293b;
        margin: 0;
    }

    .page-sub {
        color: #64748b;
        margin: .25rem 0 0;
    }

    .top-bar {
        display: flex;
        gap: 1rem;
        margin-bottom: 1.25rem;
        flex-wrap: wrap;
    }

    .search-box {
        flex: 1;
        min-width: 240px;
        position: relative;
    }

    .search-icon {
        position: absolute;
        right: .75rem;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
    }

    .search-input {
        width: 100%;
        padding: .6rem .6rem .6rem 2.2rem;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: .9rem;
        outline: none;
        background: #fff;
        box-sizing: border-box;
    }

        .search-input:focus {
            border-color: #d97706;
        }

    .mini-stat {
        background: #fff;
        border-radius: 10px;
        padding: .75rem 1.25rem;
        box-shadow: 0 1px 4px rgba(0,0,0,.07);
        text-align: center;
        min-width: 120px;
    }

    .mini-label {
        font-size: .8rem;
        color: #64748b;
        margin: 0;
    }

    .mini-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: #1e293b;
        margin: .2rem 0 0;
    }

        .mini-value.green {
            color: #16a34a;
        }

    .loading-msg {
        text-align: center;
        padding: 3rem;
        color: #64748b;
        font-size: 1rem;
    }

    .error-msg {
        background: #fef2f2;
        color: #dc2626;
        border: 1px solid #fecaca;
        border-radius: 8px;
        padding: .75rem 1rem;
        margin-bottom: 1rem;
        font-size: .875rem;
    }

    .card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 1px 6px rgba(0,0,0,.08);
        overflow: hidden;
    }

    .card-header {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #f1f5f9;
    }

    .card-title {
        font-size: 1rem;
        font-weight: 600;
        color: #1e293b;
        margin: 0;
    }

    .table-wrap {
        overflow-x: auto;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .875rem;
    }

        .data-table th {
            text-align: right;
            padding: .75rem 1rem;
            background: #f8fafc;
            color: #64748b;
            font-weight: 600;
            border-bottom: 1px solid #e2e8f0;
            white-space: nowrap;
        }

        .data-table td {
            padding: .75rem 1rem;
            border-bottom: 1px solid #f1f5f9;
            color: #334155;
        }

        .data-table tr:last-child td {
            border-bottom: none;
        }

        .data-table tr:hover td {
            background: #fafafa;
        }

    .fw-600 {
        font-weight: 600;
    }

    .empty-row {
        text-align: center;
        padding: 2.5rem !important;
        color: #94a3b8;
    }

    .cell-icon-text {
        display: flex;
        align-items: center;
        gap: .35rem;
        color: #475569;
    }

    .secondary-phone {
        color: #94a3b8;
        font-size: .8rem;
    }

    .date-cell {
        white-space: nowrap;
        color: #64748b;
        font-size: .8rem;
    }

    .badge {
        font-size: .72rem;
        padding: .2rem .6rem;
        border-radius: 999px;
        font-weight: 600;
    }

    .badge-blue {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .badge-green {
        background: #dcfce7;
        color: #15803d;
    }

    .badge-gray {
        background: #f1f5f9;
        color: #64748b;
    }

    .badge-purple {
        background: #ede9fe;
        color: #6d28d9;
    }

    .action-btns {
        display: flex;
        gap: .35rem;
    }

    .icon-btn {
        width: 30px;
        height: 30px;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        background: transparent;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #64748b;
        transition: all .2s;
    }

        .icon-btn:hover {
            border-color: #d97706;
            color: #d97706;
        }

    /* Buttons */
    .btn-primary {
        background: #d97706;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: .55rem 1.1rem;
        font-size: .9rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .4rem;
        transition: background .2s;
    }

        .btn-primary:hover:not(:disabled) {
            background: #b45309;
        }

        .btn-primary:disabled {
            opacity: .6;
            cursor: default;
        }

    .btn-outline {
        background: transparent;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: .5rem 1rem;
        font-size: .9rem;
        cursor: pointer;
        color: #475569;
        transition: all .2s;
    }

        .btn-outline:hover {
            border-color: #d97706;
            color: #d97706;
        }

    /* Dialog */
    .dialog-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.4);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .dialog {
        background: #fff;
        border-radius: 16px;
        padding: 1.5rem;
        width: 90%;
        max-width: 500px;
        box-shadow: 0 20px 60px rgba(0,0,0,.2);
        max-height: 90vh;
        overflow-y: auto;
    }

    .dialog-lg {
        max-width: 680px;
    }

    .dialog-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: .25rem;
    }

