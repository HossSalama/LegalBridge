@code {
    // ── Data
    private List<ClientSummaryDto> allClients = new();

    // ── UI State
    private bool isLoading = true;
    private bool isSaving = false;
    private string loadError = string.Empty;

    // Search
    private string searchTerm = string.Empty;

    // Add dialog
    private bool showAddDialog = false;
    private Client addModel = new();
    private string addError = string.Empty;

    // View dialog
    private bool showViewDialog = false;
    private ClientSummaryDto? viewClient;

    // Edit dialog
    private bool showEditDialog = false;
    private Client? editModel;
    private string editError = string.Empty;

    // ── Filtered list
    private IEnumerable<ClientSummaryDto> FilteredClients => allClients.Where(c =>
        string.IsNullOrWhiteSpace(searchTerm) ||
        c.FullName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
        c.Phone.Contains(searchTerm) ||
        (!string.IsNullOrEmpty(c.SecondaryPhone) && c.SecondaryPhone.Contains(searchTerm)) ||
        (!string.IsNullOrEmpty(c.Email) && c.Email.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)));

    // ── Lifecycle
    protected override async Task OnInitializedAsync()
    {
        await LoadClientsAsync();
    }

    private async Task LoadClientsAsync()
    {
        isLoading = true;
        loadError = string.Empty;
        StateHasChanged();
        try
        {
            allClients = await ClientService.GetAllClientsAsync();
        }
        catch (Exception ex)
        {
            loadError = $"حدث خطأ أثناء تحميل البيانات: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    // ── Add Dialog
    private void OpenAddDialog()
    {
        addModel = new Client { ClientType = ClientTypeEnum.Individual };
        addError = string.Empty;
        showAddDialog = true;
    }

    private void CloseAddDialog()
    {
        showAddDialog = false;
        addError = string.Empty;
    }

    private async Task HandleAddClient()
    {
        if (string.IsNullOrWhiteSpace(addModel.FullName) ||
            string.IsNullOrWhiteSpace(addModel.Phone) ||
            string.IsNullOrWhiteSpace(addModel.Address))
        {
            addError = "يرجى إدخال الاسم ورقم الهاتف والعنوان على الأقل";
            return;
        }

        isSaving = true;
        addError = string.Empty;
        try
        {
            await ClientService.AddClientAsync(addModel);
            CloseAddDialog();
            await LoadClientsAsync();
        }
        catch (Exception ex)
        {
            addError = $"حدث خطأ أثناء الحفظ: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    // ── View Dialog
    private void OpenViewDialog(ClientSummaryDto client)
    {
        viewClient = client;
        showViewDialog = true;
    }

    // ── Edit Dialog
    private async Task OpenEditDialog(int clientId)
    {
        showViewDialog = false;
        editError = string.Empty;
        try
        {
            editModel = await ClientService.GetClientByIdAsync(clientId);
            if (editModel is null)
            {
                loadError = "لم يتم العثور على العميل";
                return;
            }
            showEditDialog = true;
        }
        catch (Exception ex)
        {
            loadError = $"حدث خطأ: {ex.Message}";
        }
    }

    private void CloseEditDialog()
    {
        showEditDialog = false;
        editModel = null;
        editError = string.Empty;
    }

    private async Task HandleEditClient()
    {
        if (editModel is null) return;

        if (string.IsNullOrWhiteSpace(editModel.FullName) ||
            string.IsNullOrWhiteSpace(editModel.Phone) ||
            string.IsNullOrWhiteSpace(editModel.Address))
        {
            editError = "يرجى إدخال الاسم ورقم الهاتف والعنوان على الأقل";
            return;
        }

        isSaving = true;
        editError = string.Empty;
        try
        {
            await ClientService.UpdateClientAsync(editModel);
            CloseEditDialog();
            await LoadClientsAsync();
        }
        catch (Exception ex)
        {
            editError = $"حدث خطأ أثناء الحفظ: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }
}
