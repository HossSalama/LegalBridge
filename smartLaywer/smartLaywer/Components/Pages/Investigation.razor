@code {
    private List<InvestigationDto> investigations = new();
    private List<Case> availableCases = new();
    private InvestigationDto? selected;
    private string activeTab = "info";
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private string notes = string.Empty;
    private bool showAddModal = false;
    private bool isSaving = false;
    private string modalError = string.Empty;
    private NewInvestigationForm newInv = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }
    private void OpenAddModal()
    {
        showAddModal = true;
        StateHasChanged();
    }
    private void CloseModal()
    {
        showAddModal = false;
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = string.Empty;
        try
        {
            investigations = await InvestigationService.GetInvestigationsAsync();
            selected = investigations.FirstOrDefault();
            availableCases = await UnitOfWork.Cases.GetAllQueryableTracking()
                .Include(c => c.Client)
                .AsNoTracking()
                .ToListAsync();
        }
        catch (Exception ex) { errorMessage = $"خطأ في تحميل البيانات: {ex.Message}"; }
        finally { isLoading = false; }
    }

    private void SelectCase(InvestigationDto inv) { selected = inv; activeTab = "info"; notes = string.Empty; }

    private async Task SaveInvestigation()
    {
        modalError = string.Empty;
        if (newInv.CaseId <= 0) { modalError = "يرجى اختيار القضية"; return; }
        if (string.IsNullOrEmpty(newInv.Type)) { modalError = "يرجى اختيار نوع التحقيق"; return; }
        isSaving = true;
        try
        {
            await InvestigationService.AddInvestigationAsync(
                newInv.CaseId, newInv.Type, newInv.Status,
                newInv.StartDate, newInv.Prosecutor, newInv.Location);
            showAddModal = false;
            await LoadData();
            StateHasChanged();
        }
        catch (Exception ex) { modalError = $"خطأ في الحفظ: {ex.Message}"; }
        finally { isSaving = false; }
    }

    private string GetStatusLabel(string s) => s switch { "ongoing" => "جاري", "completed" => "مكتمل", "suspended" => "موقوف", _ => s };
    private string GetStatusBadge(string s) => s switch { "ongoing" => "badge-amber", "completed" => "badge-green", "suspended" => "badge-slate", _ => "badge-outline" };
    private string GetTypeLabel(string t) => t switch { "criminal" => "جنائي", "civil" => "مدني", "administrative" => "إداري", _ => t };
    private string GetTypeBadge(string t) => t switch { "criminal" => "badge-red", "civil" => "badge-upcoming", "administrative" => "badge-green", _ => "badge-outline" };
    private string GetRoleLabel(string r) => r switch { "plaintiff" => "مدعي", "defendant" => "متهم", "witness" => "شاهد", _ => r };
    private string GetEvidenceColor(string s) => s switch { "approved" => "#16a34a", "pending" => "#d97706", "rejected" => "#dc2626", _ => "#64748b" };

    private class NewInvestigationForm
    {
        public int CaseId { get; set; }
        public string Type { get; set; } = string.Empty;
        public string Status { get; set; } = "ongoing";
        public DateTime StartDate { get; set; } = DateTime.Today;
        public string Prosecutor { get; set; } = string.Empty;
        public string Location { get; set; } = string.Empty;
    }
}
