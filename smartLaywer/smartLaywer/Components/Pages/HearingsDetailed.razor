@code {
    private List<Case> cases = new();
    private Case? selectedCase;
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private bool showAddModal = false;
    private bool isSaving = false;
    private string modalError = string.Empty;
    private Dictionary<int, string> activeTabs = new();

    // New Hearing form
    private Hearing newHearing = new()
    {
        HearingDateTime = DateTime.Now,
        HearingType = HearingTypeEnum.Hearing,
        AttendanceStatus = AttendanceStatusEnum.Incoming,
        JudgeName = string.Empty,
        Result = string.Empty
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await LoadData();
        StateHasChanged();
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = string.Empty;
        try
        {
            cases = await UnitOfWork.Cases
                .GetAllQueryableNoTracking()
                .Include(c => c.Hearings)
                .Include(c => c.Client)
                .Include(c => c.CaseType)
                .Include(c => c.Court)
                .ToListAsync();

            selectedCase = cases.FirstOrDefault();
        }
        catch (Exception ex)
        {
            errorMessage = $"خطأ في تحميل البيانات: {ex.Message}";
        }
        finally { isLoading = false; }
    }

    private void SelectCase(Case c)
    {
        selectedCase = c;
        activeTabs.Clear();
    }

    private string GetActiveTab(int id) => activeTabs.GetValueOrDefault(id, "summary");
    private void SetTab(int id, string tab) => activeTabs[id] = tab;

    private async Task SaveSession()
    {
        modalError = string.Empty;

        if (newHearing.CaseId <= 0)
        { modalError = "يرجى اختيار قضية"; return; }

        if (string.IsNullOrWhiteSpace(newHearing.JudgeName))
            newHearing.JudgeName = "غير محدد";

        if (string.IsNullOrWhiteSpace(newHearing.Result))
            newHearing.Result = string.Empty;

        isSaving = true;
        try
        {
            // جيب الـ CourtId والـ DeptId من القضية المختارة
            var selectedC = cases.FirstOrDefault(c => c.Id == newHearing.CaseId);
            if (selectedC == null) { modalError = "القضية غير موجودة"; return; }

            newHearing.CourtId = selectedC.CourtId;
            newHearing.DeptId = selectedC.DeptId ?? 0;
            newHearing.CreatedAt = DateTime.Now;

            // جيب أول يوزر كـ CreatedBy
            var firstUserId = await UnitOfWork.Users
                .GetAllQueryableNoTracking()
                .Select(u => u.Id)
                .FirstOrDefaultAsync();

            newHearing.CreatedBy = firstUserId > 0 ? firstUserId : 1;
            newHearing.Period = newHearing.HearingDateTime.Hour < 12
                                    ? HearingPeriodEnum.Morning
                                    : HearingPeriodEnum.Evening;

            // ✅ الصح: UnitOfWork.Hearing مش HearingDetails
            await UnitOfWork.Hearing.AddAsync(newHearing);
            await UnitOfWork.CompleteAsync();

            showAddModal = false;
            successMessage = "✓ تم إضافة الجلسة بنجاح";

            // Reset form
            newHearing = new()
            {
                HearingDateTime = DateTime.Now,
                HearingType = HearingTypeEnum.Hearing,
                AttendanceStatus = AttendanceStatusEnum.Incoming,
                JudgeName = string.Empty,
                Result = string.Empty
            };

            await LoadData();

            _ = Task.Delay(3000).ContinueWith(_ =>
            {
                successMessage = string.Empty;
                InvokeAsync(StateHasChanged);
            });
        }
        catch (Exception ex)
        {
            modalError = $"خطأ في الحفظ: {ex.Message}";
        }
        finally { isSaving = false; }
    }

    private async Task SaveResult(Hearing s)
    {
        try
        {
            // الـ Hearing محملة بـ NoTracking فلازم نعمل update يدوي
            var tracked = await UnitOfWork.Hearing
                .GetAllQueryableTracking()
                .FirstOrDefaultAsync(h => h.Id == s.Id);

            if (tracked != null)
            {
                tracked.Result = s.Result;
                await UnitOfWork.CompleteAsync();
            }

            activeTabs[s.Id] = "summary";
            successMessage = "✓ تم حفظ النتيجة";
            _ = Task.Delay(2000).ContinueWith(_ => { successMessage = string.Empty; InvokeAsync(StateHasChanged); });
        }
        catch (Exception ex)
        {
            errorMessage = $"خطأ في الحفظ: {ex.Message}";
        }
    }

    private string GetStatusLabel(AttendanceStatusEnum status) => status switch
    {
        AttendanceStatusEnum.Attended => "تم الحضور",
        AttendanceStatusEnum.Absent => "غائب",
        AttendanceStatusEnum.Incoming => "قادم",
        AttendanceStatusEnum.Postponed => "مؤجل",
        _ => "غير محدد"
    };

    private string GetHearingTypeLabel(HearingTypeEnum type) => type switch
    {
        HearingTypeEnum.Hearing => "جلسة مرافعة",
        HearingTypeEnum.Investigation => "جلسة تحقيق",
        // HearingTypeEnum.Expert => "جلسة خبرة",
        // HearingTypeEnum.Other => "أخرى",
        _ => "جلسة"
    };
}
