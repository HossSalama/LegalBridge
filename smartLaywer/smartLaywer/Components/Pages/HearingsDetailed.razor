</div>

<style>
    .hd-page {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        font-family: 'Cairo', 'Segoe UI', sans-serif;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .page-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1e293b;
        margin: 0;
    }

    .page-sub {
        color: #64748b;
        margin: .25rem 0 0;
        font-size: .9rem;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
    }

    .stat-card {
        background: #fff;
        border-radius: 12px;
        padding: 1.25rem;
        box-shadow: 0 1px 6px rgba(0,0,0,.08);
    }

    .stat-body {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .stat-label {
        font-size: .85rem;
        color: #64748b;
        margin: 0;
    }

    .stat-value {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1e293b;
        margin: .2rem 0 0;
    }

        .stat-value.blue {
            color: #2563eb;
        }

        .stat-value.amber {
            color: #d97706;
        }

        .stat-value.green {
            color: #16a34a;
        }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        flex-shrink: 0;
    }

    .bg-blue {
        background: #2563eb;
    }

    .bg-amber {
        background: #d97706;
    }

    .bg-green {
        background: #16a34a;
    }

    /* Main Grid */
    .main-grid {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 1.5rem;
        align-items: start;
    }

    /* Cases Panel */
    .cases-panel, .sessions-panel {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 1px 6px rgba(0,0,0,.08);
        overflow: hidden;
    }

    .panel-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #f1f5f9;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .panel-title {
        font-size: 1rem;
        font-weight: 600;
        color: #1e293b;
        margin: 0;
    }

    .panel-sub {
        font-size: .82rem;
        color: #64748b;
        margin: .2rem 0 0;
    }

    .cases-list {
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: .75rem;
    }

    .case-item {
        padding: 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        cursor: pointer;
        transition: border-color .2s, background .2s;
    }

        .case-item:hover {
            border-color: #fbbf24;
        }

    .case-active {
        border-color: #d97706;
        background: #fffbeb;
    }

    .case-item-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: .4rem;
    }

    .case-num {
        font-weight: 600;
        color: #1e293b;
        margin: 0;
        font-size: .95rem;
    }

    .case-client {
        font-size: .83rem;
        color: #64748b;
        margin: 0 0 .4rem;
    }

    .case-court {
        display: flex;
        align-items: center;
        gap: .3rem;
        font-size: .78rem;
        color: #94a3b8;
    }

    .case-item-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: .6rem;
        padding-top: .6rem;
        border-top: 1px solid #f1f5f9;
        font-size: .78rem;
        color: #64748b;
    }

    /* Badges */
    .badge {
        font-size: .72rem;
        padding: .2rem .6rem;
        border-radius: 999px;
        font-weight: 600;
        display: inline-block;
    }

    .badge-outline {
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
    }

    .badge-upcoming {
        background: #dbeafe;
        color: #2563eb;
    }

    .badge-completed {
        background: #dcfce7;
        color: #16a34a;
    }

    .badge-postponed {
        background: #fef3c7;
        color: #d97706;
    }

    .badge-cancelled {
        background: #fee2e2;
        color: #dc2626;
    }

    /* Case Info Bar */
    .case-info-bar {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin: 1rem 1.25rem;
        background: #f8fafc;
        border-radius: 10px;
        padding: 1rem;
    }

    .info-label {
        font-size: .75rem;
        color: #64748b;
        margin: 0 0 .3rem;
    }

    .info-val {
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .875rem;
        font-weight: 500;
        color: #1e293b;
    }

    /* Timeline */
    .timeline {
        padding: 0 1.25rem 1.25rem;
