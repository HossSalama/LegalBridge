@page "/power-of-attorney"
@namespace smartLaywer.Components.Pages
@inject IDocumentService DocumentService
@using smartLaywer.DTO.Document
@inject IJSRuntime JS

<PageTitle>التوكيلات</PageTitle>

<div class="poa-page" dir="rtl">

    <!-- Header -->
    <div class="page-header-row">
        <div>
            <h1 class="page-title">التوكيلات</h1>
            <p class="page-sub">إدارة ومتابعة جميع التوكيلات القانونية</p>
        </div>
        <button class="btn-primary" @onclick="OpenUpload">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
            إضافة توكيل جديد
        </button>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-body">
                <div><p class="stat-label">إجمالي التوكيلات</p><h3 class="stat-value">@attorneys.Count</h3></div>
                <div class="stat-icon bg-blue"><svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg></div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-body">
                <div><p class="stat-label">التوكيلات السارية</p><h3 class="stat-value green">@attorneys.Count(a => a.StatusLabel == "ساري")</h3></div>
                <div class="stat-icon bg-green"><svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg></div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-body">
                <div><p class="stat-label">التوكيلات المنتهية</p><h3 class="stat-value red">@attorneys.Count(a => a.StatusLabel == "منتهي")</h3></div>
                <div class="stat-icon bg-red"><svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><line x1="15" y1="9" x2="9" y2="15" /><line x1="9" y1="9" x2="15" y2="15" /></svg></div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-body">
                <div><p class="stat-label">تنتهي قريباً</p><h3 class="stat-value amber">@attorneys.Count(a => a.ExpiryDate != "—")</h3></div>
                <div class="stat-icon bg-amber"><svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg></div>
            </div>
        </div>
    </div>

    <!-- Search -->
    <div class="search-row">
        <div class="search-box">
            <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
            <input class="search-input" placeholder="البحث بالرقم، اسم العميل، أو رقم القضية..." />
        </div>
        <button class="btn-outline">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
            تصدير
        </button>
    </div>

    <!-- Tabs -->
    <div class="tabs">
        <button class="tab tab-active">الكل </button>
        <button class="tab">ساري </button>
        <button class="tab">منتهي </button>
        <button class="tab">توكيل عام</button>
        <button class="tab">توكيل خاص</button>
    </div>

    <!-- List -->
    @if (showUpload)
    {
        <div class="modal-overlay">
            <div class="modal-content">

                <div class="modal-header">
                    <h3>إضافة توكيل</h3>
                    <button class="close-btn" @onclick="() => showUpload = false">✖</button>
                </div>

                <div class="modal-body">
                    <InputFile OnChange="OnFileSelected" />
                    <button class="btn-primary" @onclick="UploadFile">رفع</button>
                </div>

            </div>
        </div>
    }
    @if (showViewer)
    {
        <div class="modal-overlay">
            <div class="modal-content">

                <div class="modal-header">
                    <h3>عرض التوكيل</h3>
                    <button class="close-btn" @onclick="() => showViewer = false">✖</button>
                </div>

                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(currentFile))
                    {
                        <iframe src="@currentFile" width="100%" height="500px"></iframe>
                    }
                </div>

            </div>
        </div>
    }
    <div class="poa-list">
        @foreach (var a in attorneys)
        {
            <div class="poa-card">
                <div class="poa-main">
                    <div class="poa-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /><polyline points="10 9 9 9 8 9" /></svg>
                    </div>
                    <div class="poa-content">
                        <div class="poa-title-row">
                            <h3 class="poa-number">@a.Number</h3>
                            <span class="badge @a.StatusBadge">@a.StatusLabel</span>
                            <span class="badge @a.TypeBadge">@a.TypeLabel</span>
                        </div>
                        <div class="poa-meta">
                            <span>
                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                                <span class="meta-label">العميل:</span> @a.ClientName
                            </span>
                            <span>
                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" /><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" /></svg>
                                <span class="meta-label">القضية:</span> @a.CaseNumber
                            </span>
                            <span>
                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                                <span class="meta-label">تاريخ الإصدار:</span> @a.IssueDate
                            </span>
                            <span>
                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                                <span class="meta-label">تاريخ الانتهاء:</span> @a.ExpiryDate
                            </span>
                        </div>
                        <div class="poa-scope">
                            <p><strong>نطاق التوكيل: </strong>@a.Scope</p>
                            <p class="notary-num">رقم التوثيق: @a.NotaryNumber</p>
                        </div>
                    </div>
                </div>
                <div class="poa-actions">
                    <button class="btn-outline btn-sm" @onclick="() => OpenViewer(a.FilePath)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                        عرض
                    </button>
                    <button class="btn-outline btn-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                        تعديل
                    </button>
                    <button class="btn-outline btn-sm" @onclick="() => DownloadFile(a.FilePath)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
                        تحميل
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private IBrowserFile? selectedFile;
    private bool showUpload = false;
    private bool showViewer = false;
    private string? currentFile;
    private void OpenUpload()
    {
        showUpload = true;
    }
    private void OpenViewer(string path)
    {
        currentFile = path;
        showViewer = true;
    }
    private async Task ViewFile(string path)
    {
        await JS.InvokeVoidAsync("open", path, "_blank");
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
    }

    private async Task UploadFile()
    {
        if (selectedFile == null) return;

        try
        {
            long maxFileSize = 50 * 1024 * 1024;

            var ms = new MemoryStream();

            using (var stream = selectedFile.OpenReadStream(maxFileSize))
            {
                await stream.CopyToAsync(ms);
            }

            ms.Position = 0;

            var dto = new UploadDocumentDto
            {
                FileStream = ms,
                FileName = selectedFile.Name,
                ContentType = selectedFile.ContentType,
                CaseId = 1
            };

            await DocumentService.UploadDocumentAsync(dto);

            showUpload = false;
            selectedFile = null;

            await LoadData();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex); 
            await JS.InvokeVoidAsync("alert", ex.Message);
        }
    }
    private async Task LoadData()
    {
        var docs = await DocumentService.GetAllAsync();

        attorneys = docs
            .Where(d => d.DocType == DocumentTypeEnum.PowerOfAttorney)
            .Select(d => new PoaItem(
                Number: $"POA-{d.Id}",
                ClientName: d.ClientName ?? "غير معروف",
                CaseNumber: d.CaseNumber ?? "—",

                TypeLabel: "توكيل",
                TypeBadge: "badge badge-amber",

                StatusLabel: d.IsArchived ? "منتهي" : "ساري",
                StatusBadge: d.IsArchived ? "badge badge-red" : "badge badge-green",

                IssueDate: d.UploadedAt.ToString("yyyy-MM-dd"),
                ExpiryDate: d.ArchivedAt?.ToString("yyyy-MM-dd") ?? "—",

                Scope: d.Notes ?? "—",
                NotaryNumber: $"DOC-{d.Id}",

                FilePath: d.FilePath
            ))
            .ToList();
    }
    private record PoaItem(string Number, string ClientName, string CaseNumber,
        string TypeLabel, string TypeBadge, string StatusLabel, string StatusBadge,
        string IssueDate, string ExpiryDate, string Scope, string NotaryNumber,
        string FilePath);

    private List<PoaItem> attorneys = new();

    protected override async Task OnInitializedAsync()
    {
        var docs = await DocumentService.GetAllAsync();

        attorneys = docs
            .Where(d => d.DocType == DocumentTypeEnum.PowerOfAttorney)
            .Select(d => new PoaItem(
                Number: $"POA-{d.Id}",
                ClientName: d.ClientName ?? "غير معروف",
                CaseNumber: d.CaseNumber ?? "—",

                TypeLabel: "توكيل",
                TypeBadge: "badge badge-amber",

                StatusLabel: d.IsArchived ? "منتهي" : "ساري",
                StatusBadge: d.IsArchived ? "badge badge-red" : "badge badge-green",

                IssueDate: d.UploadedAt.ToString("yyyy-MM-dd"),
                ExpiryDate: d.ArchivedAt?.ToString("yyyy-MM-dd") ?? "—",

                Scope: d.Notes ?? "—",
                NotaryNumber: $"DOC-{d.Id}",

                FilePath: d.FilePath
            ))
            .ToList();
    }

    private async Task DownloadFile(string path)
    {
        await JS.InvokeVoidAsync("open", path, "_blank");
    }

}

