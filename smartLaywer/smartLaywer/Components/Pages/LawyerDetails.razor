        <h1 class="page-title">„·ð «·„Õ«„Ì</h1>
    </div>

    @if (lawyer == null)
    {
        <div class="loader-box">Ã«—Ì  Õ„Ì· «·»Ì«‰« ...</div>
    }
    else
    {
        <div class="details-grid">
            <div class="detail-card main-info">
