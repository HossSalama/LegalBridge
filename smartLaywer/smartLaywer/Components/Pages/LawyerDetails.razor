        "Administrative" => ("≈œ«—Ì", "badge-green"),
        _ => ("√Œ—Ï", "badge-gray")
    };
    protected override async Task OnInitializedAsync()
    {
        try
        {
            lawyer = await AuthService.GetUserDetailsAsync(Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
