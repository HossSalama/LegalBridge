    }

    .page-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .btn-back {
        background: none;
        border: 1px solid #e2e8f0;
        padding: .5rem 1rem;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .5rem;
        color: #64748b;
    }

    .details-grid {
        display: grid;
        grid-template-columns: 350px 1fr;
        gap: 1.5rem;
    }

    .detail-card {
        background: #fff;
        border-radius: 12px;
