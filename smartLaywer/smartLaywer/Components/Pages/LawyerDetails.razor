                    <span class="label">«·—Þ„ «·ÞÊ„Ì:</span>
                    <span class="value">@lawyer.NationalId</span>
                </div>
            </div>

            <div class="detail-card cases-info">
                <h3>«·Þ÷«Ì« «·„Êþ·… ≈·ÌÂ (@lawyer.AssignedCases?.Count() ?? 0)</h3>
                <div class="table-wrap">
