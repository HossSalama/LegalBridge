</div>

<style>
    .badge-blue {
        background: #dbeafe;
        color: #1d4ed8;
    }
    /* „œ‰Ì */
    .badge-red {
        background: #fee2e2;
        color: #dc2626;
    }
    /* Ã‰«∆Ì */
    .badge-orange {
        background: #ffedd5;
        color: #ea580c;
    }
    /*  Ã«—Ì */
    .badge-purple {
        background: #f3e8ff;
        color: #9333ea;
    }
    /* √”—… */
    .badge-green {
        background: #dcfce7;
        color: #16a34a;
    }
    /* ≈œ«—Ì */
