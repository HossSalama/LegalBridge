@page "/hearings"
@namespace smartLaywer.Components.Pages
@using smartLaywer.DTO.Court
@using smartLaywer.DTO.Department

<PageTitle>إدارة الجلسات</PageTitle>

<div class="hearings-page" dir="rtl">

    <!-- Header -->
    <div class="page-header">
        <div>
            <h1 class="page-title">إدارة الجلسات</h1>
            <p class="page-sub">عرض وجدولة جميع الجلسات القضائية</p>
        </div>
        <button class="btn-primary" @onclick="() => showModal = true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            جدولة جلسة جديدة
        </button>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-body">
                <div>
                    <p class="stat-label">جلسات قادمة</p>
                    <h3 class="stat-value blue">@summary.UpcomingHearingsCount</h3>
                </div>
                <div class="stat-icon bg-blue">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" />
                        <line x1="16" y1="2" x2="16" y2="6" />
                        <line x1="8" y1="2" x2="8" y2="6" />
                        <line x1="3" y1="10" x2="21" y2="10" />
                    </svg>
                </div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-body">
                <div>
                    <p class="stat-label">جلسات اليوم</p>
                    <h3 class="stat-value amber">@summary.TodayHearingsCount</h3>
                </div>
                <div class="stat-icon bg-amber">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <polyline points="12 6 12 12 16 14" />
                    </svg>
                </div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-body">
                <div>
                    <p class="stat-label">جلسات مكتملة</p>
                    <h3 class="stat-value green">@summary.CompletedHearingsCount</h3>
                </div>
                <div class="stat-icon bg-green">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                        <polyline points="22 4 12 14.01 9 11.01" />
                    </svg>
                </div>
            </div>
        </div>
    </div>
    <div class="filter-bar">
        <div style="display:flex; gap:1rem; align-items:center; width:100%;">
            <label class="filter-label">تصفية حسب الحالة:</label>
            <select class="filter-select" @onchange="OnStatusChanged">
                <option value="الكل">جميع الجلسات</option>
                <option value="قادم">قادمة</option>
                <option value="مكتمله">مكتملة</option>
                <option value="غائب">غائب</option>
            </select>

            @* إضافة حقل بحث *@
            <input type="text" placeholder="ابحث برقم القضية أو اسم العميل..."
                   class="filter-select" style="margin-right:auto; width:300px;"
                   @oninput="OnSearchChanged" />
        </div>
    </div>

    <div class="table-card">
        <div class="table-header">
            <h2 class="table-title">قائمة الجلسات (@(pagedHearings?.TotalCount ?? 0))</h2>
        </div>
        <div class="table-wrap">
            <table class="hearings-table">
                <thead>
                    <tr>
                        <th>رقم القضية</th>
                        <th>عنوان القضية</th>
                        <th>العميل</th>
                        <th>التاريخ والوقت</th>
                        <th>المحكمة / الدائرة</th>
                        <th>الحالة</th>
                        <th>النتيجة</th>
                        <th>الملاحظات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (pagedHearings?.Items != null)
                    {
                        @foreach (var hearing in pagedHearings.Items)
                        {
                            <tr>
                                <td class="font-med">@hearing.CaseNumber</td>
                                <td>@hearing.CaseTitle</td>
                                <td>@hearing.ClientName</td>
                                <td>
                                    <div class="datetime-cell">
                                        <span class="dt-date">
                                            <i class="bi bi-calendar3"></i> @hearing.HearingDateTime.ToString("yyyy-MM-dd")
                                        </span>
                                        <span class="dt-time">
                                            <i class="bi bi-clock"></i> @hearing.HearingDateTime.ToString("HH:mm")
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    <span class="court-cell">
                                        <i class="bi bi-geo-alt"></i> @hearing.CourtName - @hearing.DepartmentName
                                    </span>
                                </td>
                                <td>
                                    <span class="badge @(GetBadgeClass(hearing.Status))">@hearing.Status</span>
                                </td>
                                <td>
                                    <span class="@(string.IsNullOrEmpty(hearing.Result) ? "muted" : "result-text")">
                                        @(string.IsNullOrEmpty(hearing.Result) ? "-" : hearing.Result)
                                    </span>
                                </td>
                                <td><span class="note-text">@hearing.Notes</span></td>
                                <td>
                                    <div class="action-btns">
                                        <button class="icon-btn" title="عرض التفاصيل" @onclick="() => OpenViewDialog(hearing.Id)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                                 fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                                <circle cx="12" cy="12" r="3" />
                                            </svg>
                                        </button>
                                        <button class="icon-btn" title="تعديل" @onclick="() => OpenEditDialog(hearing.Id)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                                 fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                            </svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @* إضافة أزرار التنقل (Pagination) *@
        @if (pagedHearings != null && pagedHearings.TotalPages > 1)
        {
            <div class="pagination-bar" style="padding: 1rem; display: flex; justify-content: center; gap: 0.5rem;">
                <button class="btn-outline" disabled="@(!pagedHearings.HasPreviousPage)"
                        @onclick="() => ChangePage(currentPage - 1)">
                    السابق
                </button>
                <span style="align-self: center;">صفحة @currentPage من @pagedHearings.TotalPages</span>
                <button class="btn-outline" disabled="@(!pagedHearings.HasNextPage)"
                        @onclick="() => ChangePage(currentPage + 1)">
                    التالي
                </button>
            </div>
        }
    </div>
</div>
@if (showViewModal && selectedHearing != null)
{
    <div class="modal-overlay" @onclick="() => showViewModal = false">
        <div class="modal-box details-modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div>
                    <h3 class="modal-title">تفاصيل الجلسة</h3>
                    <small class="text-muted">قضية رقم: @selectedHearing.CaseNumber</small>
                </div>
                <button class="modal-close" @onclick="() => showViewModal = false">✕</button>
            </div>

            <div class="modal-body">
                <div class="info-section">
                    <h5 class="section-title"><i class="bi bi-briefcase"></i> بيانات الدعوى</h5>
                    <div class="details-grid">
                        <div class="info-item"><strong>اسم الدعوى:</strong> <span>@selectedHearing.CaseTitle</span></div>
                        <div class="info-item"><strong>الموكل:</strong> <span>@selectedHearing.ClientName</span></div>
                        <div class="info-item"><strong>تليفون الموكل:</strong> <span>@selectedHearing.ClientPhone</span></div>
                        <div class="info-item"><strong>المرحلة:</strong> <span>@selectedHearing.CaseStage</span></div>
                    </div>
                </div>

                <div class="info-section mt-3">
                    <h5 class="section-title"><i class="bi bi-geo-alt"></i> مكان وموعد الجلسة</h5>
                    <div class="details-grid">
                        <div class="info-item"><strong>المحكمة:</strong> <span>@selectedHearing.CourtName</span></div>
                        <div class="info-item"><strong>الدائرة:</strong> <span>@selectedHearing.DepartmentName</span></div>
                        <div class="info-item"><strong>التاريخ:</strong> <span>@selectedHearing.HearingDateTime.ToString("dd/MM/yyyy")</span></div>
                        <div class="info-item"><strong>الوقت:</strong> <span>@selectedHearing.HearingDateTime.ToString("hh:mm tt") (@selectedHearing.Period)</span></div>
                    </div>
                </div>

                <div class="info-section mt-3">
                    <h5 class="section-title"><i class="bi bi-journal-text"></i> ما تم في الجلسة</h5>
                    <div class="result-display-box">
                        <label>القرار / النتيجة:</label>
                        <p class="@(string.IsNullOrEmpty(selectedHearing.Result) ? "text-muted" : "")">
                            @(string.IsNullOrEmpty(selectedHearing.Result) ? "لا يوجد نتيجة مسجلة بعد" : selectedHearing.Result)
                        </p>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn-outline" @onclick="() => showViewModal = false">إغلاق</button>
                <button class="btn-primary" @onclick="() => OpenEditDialog(selectedHearing.Id)">تعديل النتيجة</button>
            </div>
        </div>
    </div>
}
@if (showModal)
{
    <div class="modal-overlay" @onclick="() => showModal = false">
        <div class="modal-box" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3 class="modal-title">جدولة جلسة جديدة</h3>
                <button class="modal-close" @onclick="() => showModal = false">✕</button>
            </div>
            <p class="modal-sub">أدخل بيانات الجلسة الجديدة</p>

            <EditForm Model="hearingModel" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <div class="modal-body">
                    <div class="form-group">
                        <label>القضية المرتبطة *</label>
                        <InputSelect @bind-Value="hearingModel.CaseId" class="form-input">
                            <option value="0">-- اختر القضية --</option>
                            @foreach (var c in casesList)
                            {
                                <option value="@c.Id">@c.CaseNumber - @c.ClientName</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="form-row" style="display:flex; gap:1rem;">
                        <div class="form-group" style="flex:1">
                            <label>المحكمة *</label>
                            <select class="form-input" @onchange="OnCourtSelectionChanged">
                                <option value="0">-- اختر المحكمة --</option>
                                @foreach (var court in courtsList)
                                {
                                    <option value="@court.Id">@court.Name</option>
                                }
                            </select>
                        </div>

                        <div class="form-group" style="flex:1">
                            <label>الدائرة *</label>
                            <InputSelect @bind-Value="hearingModel.DeptId" class="form-input">
                                <option value="0">-- اختر الدائرة --</option>
                                @foreach (var dept in departmentsList)
                                {
                                    <option value="@dept.Id">@dept.Name</option>
                                }
                            </InputSelect>
                        </div>
                    </div>

                    <div class="form-row" style="display:flex; gap:1rem;">
                        <div class="form-group" style="flex:1">
                            <label>نوع الجلسة *</label>
                            <InputSelect @bind-Value="hearingModel.HearingType" class="form-input">
                                @foreach (var type in Enum.GetValues(typeof(smartLaywer.Enum.HearingTypeEnum)))
                                {
                                    <option value="@type">@GetDisplayName((Enum)type)</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-group" style="flex:1">
                            <label>الفترة *</label>
                            <InputSelect @bind-Value="hearingModel.Period" class="form-input">
                                @foreach (var period in Enum.GetValues(typeof(smartLaywer.Enum.HearingPeriodEnum)))
                                {
                                    <option value="@period">@GetDisplayName((Enum)period)</option>
                                }
                            </InputSelect>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>التاريخ والوقت *</label>
                        <InputDate Type="InputDateType.DateTimeLocal"
                                   @bind-Value="hearingModel.HearingDateTime"
                                   class="form-input" />
                    </div>

                    <div class="form-group">
                        <label>اسم القاضي</label>
                        <InputText @bind-Value="hearingModel.JudgeName" placeholder="اسم القاضي" class="form-input" />
                    </div>

                    <div class="form-group">
                        <label>النتيجة / ملاحظات</label>
                        <InputTextArea @bind-Value="hearingModel.Result" placeholder="أي ملاحظات أو نتائج..." class="form-textarea" rows="3"></InputTextArea>
                    </div>

                    <div class="alert-info">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;margin-top:2px">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="8" x2="12" y2="12" />
                            <line x1="12" y1="16" x2="12.01" y2="16" />
                        </svg>
                        <div>
                            <p class="alert-title">سيتم إنشاء تنبيهات تلقائية:</p>
                            <ul class="alert-list">
                                <li>قبل الجلسة بـ 24 ساعة</li>
                                <li>قبل الجلسة بساعتين</li>
                            </ul>
                        </div>
                    </div>

                    <div class="modal-actions">
                        <button type="submit" class="btn-primary" style="flex:1">حفظ</button>
                        <button type="button" class="btn-outline" style="flex:1" @onclick="() => showModal = false">إلغاء</button>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (showUpdateModal)
{
    <div class="modal-overlay" @onclick="() => showUpdateModal = false">
        <div class="modal-box" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3 class="modal-title">تحديث نتيجة الجلسة</h3>
                <button class="modal-close" @onclick="() => showUpdateModal = false">✕</button>
            </div>

            <EditForm Model="updateModel" OnValidSubmit="HandleUpdateSubmit">
                <DataAnnotationsValidator />

                <div class="modal-body">
                    <div class="form-group">
                        <label>حالة الجلسة *</label>
                        <InputSelect @bind-Value="updateModel.Status" class="form-input">
                            @foreach (var status in Enum.GetValues(typeof(smartLaywer.Enum.AttendanceStatusEnum)))
                            {
                                <option value="@status">@GetDisplayName((Enum)status)</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="form-group">
                        <label>قرار المحكمة / النتيجة</label>
                        <InputTextArea @bind-Value="updateModel.Result" class="form-textarea" rows="3" placeholder="اكتب ما تم في الجلسة..." />
                    </div>

                    <hr />
                    <p class="text-muted" style="font-size: 0.8rem; margin-bottom: 0.5rem;">جدولة جلسة قادمة (اختياري)</p>

                    <div class="form-row">
                        <div class="form-group">
                            <label>تاريخ الجلسة القادمة</label>
                            <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="updateModel.NextHearingDate" class="form-input" />
                        </div>
                        <div class="form-group">
                            <label>الفترة</label>
                            <InputSelect @bind-Value="updateModel.NextHearingPeriod" class="form-input">
                                <option value="">-- اختر الفترة --</option>
                                @foreach (var period in Enum.GetValues(typeof(smartLaywer.Enum.HearingPeriodEnum)))
                                {
                                    <option value="@period">@GetDisplayName((Enum)period)</option>
                                }
                            </InputSelect>
                        </div>
                    </div>

                    <div class="modal-actions">
                        <button type="submit" class="btn-primary" style="flex:1">حفظ النتيجة والجدولة</button>
                        <button type="button" class="btn-outline" style="flex:1" @onclick="() => showUpdateModal = false">إلغاء</button>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>
}
<style>
    .hearings-page {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        font-family: 'Cairo', 'Segoe UI', sans-serif;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .page-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1e293b;
        margin: 0;
    }

    .page-sub {
        color: #64748b;
        margin: .25rem 0 0;
        font-size: .9rem;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
    }

    .stat-card {
        background: #fff;
        border-radius: 12px;
        padding: 1.25rem;
        box-shadow: 0 1px 6px rgba(0,0,0,.08);
    }

    .stat-body {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .stat-label {
        font-size: .85rem;
        color: #64748b;
        margin: 0;
    }

    .stat-value {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1e293b;
        margin: .2rem 0 0;
    }

        .stat-value.blue {
            color: #2563eb;
        }

        .stat-value.amber {
            color: #d97706;
        }

        .stat-value.green {
            color: #16a34a;
        }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        flex-shrink: 0;
    }

    .bg-blue {
        background: #2563eb;
    }

    .bg-amber {
        background: #d97706;
    }

    .bg-green {
        background: #16a34a;
    }

    .filter-bar {
        display: flex;
        align-items: center;
        gap: 1rem;
        background: #fff;
        padding: 1rem 1.25rem;
        border-radius: 12px;
        box-shadow: 0 1px 6px rgba(0,0,0,.08);
    }

    .filter-label {
        font-size: .9rem;
        font-weight: 600;
        color: #334155;
        white-space: nowrap;
    }

    .filter-select {
        padding: .55rem .875rem;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-family: inherit;
        font-size: .9rem;
        outline: none;
        color: #475569;
        min-width: 180px;
    }

        .filter-select:focus {
            border-color: #d97706;
        }

    .table-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 1px 6px rgba(0,0,0,.08);
        overflow: hidden;
    }

    .table-header {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #f1f5f9;
    }

    .table-title {
        font-size: 1rem;
        font-weight: 600;
        color: #1e293b;
        margin: 0;
    }

    .table-wrap {
        overflow-x: auto;
    }

    .hearings-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .875rem;
    }

        .hearings-table th {
            padding: .75rem 1rem;
            text-align: right;
            font-size: .8rem;
            font-weight: 600;
            color: #64748b;
            background: #f8fafc;
            border-bottom: 1px solid #e2e8f0;
            white-space: nowrap;
        }

        .hearings-table td {
            padding: .875rem 1rem;
            border-bottom: 1px solid #f1f5f9;
            color: #334155;
            vertical-align: middle;
        }

        .hearings-table tr:last-child td {
            border-bottom: none;
        }

        .hearings-table tr:hover td {
            background: #fafafa;
        }

    .font-med {
        font-weight: 600;
    }

    .datetime-cell {
        display: flex;
        flex-direction: column;
        gap: .3rem;
    }

    .dt-date, .dt-time {
        display: flex;
        align-items: center;
        gap: .3rem;
        font-size: .82rem;
    }

    .dt-time {
        color: #64748b;
    }

    .court-cell {
        display: flex;
        align-items: center;
        gap: .3rem;
        font-size: .82rem;
        white-space: nowrap;
    }

    .badge {
        font-size: .72rem;
        padding: .2rem .6rem;
        border-radius: 999px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: .25rem;
    }

    .badge-upcoming {
        background: #dbeafe;
        color: #2563eb;
    }

    .badge-completed {
        background: #dcfce7;
        color: #16a34a;
    }

    .badge-cancelled {
        background: #fee2e2;
        color: #dc2626;
    }

    .muted {
        color: #94a3b8;
        font-size: .82rem;
    }

    .result-text {
        font-size: .82rem;
        color: #334155;
    }

    .note-text {
        font-size: .82rem;
        color: #64748b;
    }

    .urgent-note {
        color: #dc2626;
        font-weight: 600;
    }

    .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: #d97706;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: .6rem 1.2rem;
        font-family: inherit;
        font-size: .9rem;
        font-weight: 600;
        cursor: pointer;
        transition: background .2s;
    }

        .btn-primary:hover {
            background: #b45309;
        }

    .btn-outline {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: transparent;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: .6rem 1.2rem;
        font-family: inherit;
