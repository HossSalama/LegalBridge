@code {
    [Inject] private IHearingService HearingService { get; set; }
    [Inject] private ICourtService CourtService { get; set; }
    [Inject] private IDepartmentService DepartmentService { get; set; }
    [Inject] private ICaseService CaseService { get; set; } 

    private HearingCreationDto hearingModel = new();
    private bool showModal = false;
    private HearingSummaryDto summary = new();
    private IEnumerable<CaseViewDto> casesList = new List<CaseViewDto>();
    private IEnumerable<CourtViewDto> courtsList = new List<CourtViewDto>();
    private IEnumerable<DeptViewDto> departmentsList = new List<DeptViewDto>();
    private PaginatedList<HearingDisplayDto> pagedHearings;
    private string selectedStatus = "الكل";
    private string searchTerm = "";
    private int currentPage = 1;
    private bool showUpdateModal = false;
    private UpdateHearingResultDto updateModel = new();
    private bool showViewModal = false;
    private HearingDetailsDto? selectedHearing;

    private async Task OpenViewDialog(int id)
    {
       selectedHearing = await HearingService.GetHearingDetailsAsync(id);

        if (selectedHearing != null)
        {
            showViewModal = true;
            StateHasChanged();
        }
    }
    private void OpenEditDialog(int hearingId)
    {
        updateModel = new UpdateHearingResultDto 
        { 
            Id = hearingId,
            Status = AttendanceStatusEnum.Attended 
        };
        showUpdateModal = true;
    }
    private async Task HandleUpdateSubmit()
    {
        var result = await HearingService.UpdateHearingAndScheduleNextAsync(updateModel);
        if (result)
        {
            showUpdateModal = false;
            await LoadHearings();
            summary = await HearingService.GetHearingsSummaryAsync(); 
            StateHasChanged();
        }
    }
    protected override async Task OnInitializedAsync()
    {
        casesList = await CaseService.GetAllCasesForDropdownAsync();
        courtsList = await CourtService.GetAllCourtsAsync();
        summary = await HearingService.GetHearingsSummaryAsync();
        await LoadHearings();
    }
    private async Task LoadHearings()
    {
        pagedHearings = await HearingService.GetHearingsForGridAsync(currentPage, selectedStatus, searchTerm);
    }

    private async Task ChangePage(int newPage)
    {
        currentPage = newPage;
        await LoadHearings();
    }

    private string GetBadgeClass(string status)
    {
        if (string.IsNullOrEmpty(status)) return "badge-upcoming";
        return status switch
        {
            "قادمة" => "badge-upcoming", 
            "مكتملة" => "badge-completed",
            "ملغية" => "badge-cancelled", 
            _ => "badge-outline"
        };
    }

    private async Task OnStatusChanged(ChangeEventArgs e)
    {
        selectedStatus = e.Value?.ToString() ?? "الكل";
        currentPage = 1; 
        await LoadHearings();
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        currentPage = 1;
        await LoadHearings();
    }


    private async Task OnCourtSelectionChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int courtId))
        {
            hearingModel.CourtId = courtId;
            if (courtId > 0)
            {
                departmentsList = await DepartmentService.GetDeptsByCourtIdAsync(courtId);
            }
            else
            {
                departmentsList = new List<DeptViewDto>();
                hearingModel.DeptId = 0;
            }
        }
    }

    private async Task HandleSubmit()
    {
        if (hearingModel.CaseId == 0 || hearingModel.CourtId == 0 || hearingModel.DeptId == 0)
        {
            return;
        }
        hearingModel.AttendanceStatus = AttendanceStatusEnum.Incoming;
        var result = await HearingService.CreateHearingAsync(hearingModel);
        if (result)
        {
            showModal = false;
            await LoadHearings(); 
            StateHasChanged();
        }
    }

    private string GetDisplayName(Enum value)
    {
        var field = value.GetType().GetField(value.ToString());
        var attribute = (System.ComponentModel.DataAnnotations.DisplayAttribute)
            Attribute.GetCustomAttribute(field, typeof(System.ComponentModel.DataAnnotations.DisplayAttribute));
        return attribute?.Name ?? value.ToString();
    }
}
