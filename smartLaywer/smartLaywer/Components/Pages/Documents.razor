@page "/documents"
@namespace smartLaywer.Components.Pages
@using smartLaywer.DTO.Documents
@using smartLaywer.Services.InterfaceService
@using smartLaywer.Services.ClassService
@using smartLaywer.Models
@using smartLaywer.Enum
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IDocumentService DocumentService
@inject ICaseService CaseService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>إدارة المستندات</PageTitle>

<!-- ══════════════════════════════════════════════════════════
     MAIN PAGE CONTENT  (لا يحتوي على أي modal)
     ══════════════════════════════════════════════════════════ -->
<div class="docs-page" dir="rtl">

    <!-- Header -->
    <div class="page-header-row">
        <div>
            <h1 class="page-title">إدارة المستندات</h1>
            <p class="page-sub">عرض وإدارة جميع المستندات والملفات</p>
        </div>
        <button class="btn-primary" @onclick="OpenUploadModal">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                <polyline points="17 8 12 3 7 8" />
                <line x1="12" y1="3" x2="12" y2="15" />
            </svg>
            رفع مستند جديد
        </button>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-body">
                <div>
                    <p class="stat-label">إجمالي المستندات</p>
                    <h3 class="stat-value">@(stats?.Total ?? 0)</h3>
                </div>
                <div class="stat-icon bg-blue">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                        <polyline points="14 2 14 8 20 8" />
                    </svg>
                </div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-body">
                <div>
                    <p class="stat-label">مستندات PDF</p>
                    <h3 class="stat-value red">@(stats?.PdfCount ?? 0)</h3>
                </div>
                <div class="stat-icon bg-red">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z" />
                        <polyline points="13 2 13 9 20 9" />
                    </svg>
                </div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-body">
                <div>
                    <p class="stat-label">مستندات Word</p>
                    <h3 class="stat-value blue">@(stats?.WordCount ?? 0)</h3>
                </div>
                <div class="stat-icon bg-blue">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z" />
                        <polyline points="13 2 13 9 20 9" />
                    </svg>
                </div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-body">
                <div>
                    <p class="stat-label">الحجم الإجمالي</p>
                    <h3 class="stat-value">@(stats?.TotalSizeDisplay ?? "0 B")</h3>
                </div>
                <div class="stat-icon bg-green">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                        <polyline points="14 2 14 8 20 8" />
                        <line x1="16" y1="13" x2="8" y2="13" />
                        <line x1="16" y1="17" x2="8" y2="17" />
                    </svg>
                </div>
            </div>
        </div>
    </div>

    <!-- Load Error -->
    @if (!string.IsNullOrEmpty(loadErrorMsg))
    {
        <div class="error-msg" @onclick='() => loadErrorMsg = string.Empty' style="cursor:pointer">
            ⚠️ @loadErrorMsg &nbsp;<small>(اضغط للإغلاق)</small>
        </div>
    }

    <!-- Search -->
    <div class="card">
        <div class="card-body">
            <div class="search-wrap">
                <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
                <input type="text"
                       class="search-input"
                       placeholder="ابحث في المستندات (العنوان، رقم القضية، اسم القضية)"
                       value="@searchTerm"
                       @oninput="OnSearchChanged" />
                @if (!string.IsNullOrEmpty(searchTerm))
                {
                    <button class="search-clear-btn" @onclick="ClearSearch">✕</button>
                }
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">قائمة المستندات (@filteredDocuments.Count)</h2>
        </div>

        @if (isLoading)
        {
            <div class="loading-msg" style="padding:2rem;text-align:center;">
                جاري تحميل المستندات...
            </div>
        }
        else
        {
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>اسم المستند</th>
                            <th>رقم القضية</th>
                            <th>عنوان القضية</th>
                            <th>النوع</th>
                            <th>الامتداد</th>
                            <th>الحجم</th>
                            <th>تاريخ الرفع</th>
                            <th>رفع بواسطة</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!filteredDocuments.Any())
                        {
                            <tr>
                                <td colspan="9" style="text-align:center;padding:2rem;color:#94a3b8;">
                                    @if (string.IsNullOrEmpty(searchTerm))
                                    {
                                        <span>لا توجد مستندات حتى الآن. ابدأ برفع مستند جديد.</span>
                                    }
                                    else
                                    {
                                        <span>لا توجد نتائج للبحث عن "<strong>@searchTerm</strong>"</span>
                                    }
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var doc in filteredDocuments)
                            {
                                <tr>
                                    <td>
                                        <div class="file-name-cell">
                                            <span class="file-ext-badge @GetExtClass(doc.FileExtension)">
                                                @doc.FileExtension
                                            </span>
                                            @doc.Title
                                        </div>
                                    </td>
                                    <td class="fw-600">@(string.IsNullOrEmpty(doc.CaseNumber) ? "—" : doc.CaseNumber)</td>
                                    <td>@doc.CaseTitle</td>
                                    <td><span class="badge badge-soft-blue">@doc.DocTypeDisplay</span></td>
                                    <td><span class="badge badge-outline-gray">@doc.FileExtension</span></td>
                                    <td class="text-muted">@doc.FileSizeDisplay</td>
                                    <td class="text-muted">@doc.UploadedAt.ToString("yyyy/MM/dd")</td>
                                    <td>@doc.UploadedByName</td>
                                    <td>
                                        <div class="action-btns">
                                            <button class="icon-btn" title="عرض التفاصيل"
                                                    @onclick="() => OpenDetailsModal(doc)">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15"
                                                     viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                                    <circle cx="12" cy="12" r="3" />
                                                </svg>
                                            </button>
                                            <!-- تحميل مباشر عبر رابط href بدون JS -->
                                            <a class="icon-btn" title="تحميل الملف"
                                               href="@doc.FilePath.Replace("\\", "/")" download="@(doc.Title + "." + doc.FileExtension.ToLower())">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15"
                                                     viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                                                    <polyline points="7 10 12 15 17 10" />
                                                    <line x1="12" y1="15" x2="12" y2="3" />
                                                </svg>
                                            </a>
                                            <button class="icon-btn icon-btn-danger" title="حذف"
                                                    @onclick="() => OpenDeleteConfirm(doc)">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15"
                                                     viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <polyline points="3 6 5 6 21 6" />
                                                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                                                    <path d="M10 11v6M14 11v6" />
                                                    <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" />
                                                </svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

</div>
<!-- ← نهاية .docs-page — كل الـ modals تأتي بعد هذا السطر تماماً -->
<!-- ══════════════════════════════════════════════════════════
     MODAL: رفع مستند جديد
     يجب أن يكون خارج .docs-page حتى يعمل position:fixed بشكل صحيح
     ══════════════════════════════════════════════════════════ -->
@if (showUploadModal)
{
    <div class="modal-overlay" @onclick="CloseUploadModal">
        <div class="modal-box modal-lg" @onclick:stopPropagation="true" dir="rtl">
            <div class="modal-header">
                <h3 class="modal-title">رفع مستند جديد</h3>
                <button class="modal-close" @onclick="CloseUploadModal" disabled="@isSaving">✕</button>
            </div>
            <p class="modal-sub">أدخل بيانات المستند واختر الملف المراد رفعه</p>

            @if (!string.IsNullOrEmpty(uploadErrorMsg))
            {
                <div class="error-msg" style="margin:0 1.5rem .5rem;">⚠️ @uploadErrorMsg</div>
            }

            <div class="modal-body">
                <div class="form-row">
                    <!-- عنوان المستند -->
                    <div class="form-group" style="flex:2">
                        <label>عنوان المستند <span style="color:#dc2626">*</span></label>
                        <input class="form-input" @bind="uploadDto.Title"
                               placeholder="مثال: عقد البيع - محمد أحمد" />
                    </div>
                    <!-- نوع المستند -->
                    <div class="form-group" style="flex:1">
                        <label>نوع المستند <span style="color:#dc2626">*</span></label>
                        <select class="form-input" @bind="uploadDto.DocType">
                            <option value="@DocumentTypeEnum.Memo">مذكرة</option>
                            <option value="@DocumentTypeEnum.PowerOfAttorney">توكيل</option>
                            <option value="@DocumentTypeEnum.Judgment">حكم</option>
                            <option value="@DocumentTypeEnum.Contract">عقد</option>
                            <option value="@DocumentTypeEnum.Image">صورة</option>
                            <option value="@DocumentTypeEnum.Report">تقرير</option>
                            <option value="@DocumentTypeEnum.Receipt">إيصال</option>
                            <option value="@DocumentTypeEnum.Other">أخرى</option>
                        </select>
                    </div>
                </div>

                <!-- القضية -->
                <div class="form-group">
                    <label>القضية المرتبطة <span style="color:#dc2626">*</span></label>
                    <select class="form-input" @bind="uploadDto.CaseId">
                        <option value="0">-- اختر القضية --</option>
                        @foreach (var c in allCases)
                        {
                            <option value="@c.Id">
                                @(string.IsNullOrEmpty(c.CaseNumber) ? c.Title : $"{c.CaseNumber} — {c.Title}")
                            </option>
                        }
                    </select>
                </div>

                <!-- اختيار الملف -->
                <div class="form-group">
                    <label>الملف <span style="color:#dc2626">*</span></label>
                    <div class="file-pick-zone @(selectedFile != null ? "file-pick-ready" : "")">
                        <InputFile OnChange="OnFileSelected"
                                   accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.gif,.xls,.xlsx,.ppt,.pptx,.txt"
                                   id="docFileInput"
                                   style="position:absolute;width:1px;height:1px;opacity:0;" />
                        <label for="docFileInput" class="file-pick-label">
                            @if (selectedFile == null)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
                                     fill="none" stroke="#94a3b8" stroke-width="1.5">
                                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                                    <polyline points="17 8 12 3 7 8" />
                                    <line x1="12" y1="3" x2="12" y2="15" />
                                </svg>
                                <span style="font-weight:600;color:#374151;">اضغط لاختيار الملف</span>
                                <span style="font-size:.78rem;color:#94a3b8;">PDF, DOCX, DOC, JPG, PNG, XLSX — الحد الأقصى: 10 MB</span>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24"
                                     fill="none" stroke="#16a34a" stroke-width="2">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                    <polyline points="14 2 14 8 20 8" />
                                    <polyline points="9 15 12 18 15 15" />
                                    <line x1="12" y1="12" x2="12" y2="18" />
                                </svg>
                                <span style="font-weight:600;color:#16a34a;">@selectedFile.Name</span>
                                <span style="font-size:.78rem;color:#64748b;">@FormatFileSize(selectedFile.Size) — اضغط لتغيير الملف</span>
                            }
                        </label>
                    </div>
                </div>

                <!-- ملاحظات -->
                <div class="form-group">
                    <label>ملاحظات (اختياري)</label>
                    <textarea class="form-input" rows="2"
                              @bind="uploadDto.Notes"
                              placeholder="أي ملاحظات إضافية..."></textarea>
                </div>
            </div>

            <div class="modal-actions">
                <button class="btn-secondary" @onclick="CloseUploadModal" disabled="@isSaving">إلغاء</button>
                <button class="btn-primary" @onclick="SubmitUpload" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <span>جاري الرفع...</span>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                            <polyline points="17 8 12 3 7 8" />
                            <line x1="12" y1="3" x2="12" y2="15" />
                        </svg>
                        <span>رفع المستند</span>
                    }
                </button>
            </div>
        </div>
    </div>
}


<!-- ══════════════════════════════════════════════════════════
     MODAL: عرض تفاصيل مستند
     ══════════════════════════════════════════════════════════ -->
@if (showDetailsModal && selectedDoc != null)
{
    <div class="modal-overlay" @onclick="CloseDetailsModal">
        <div class="modal-box" @onclick:stopPropagation="true" dir="rtl">
            <div class="modal-header">
                <h3 class="modal-title">تفاصيل المستند</h3>
                <button class="modal-close" @onclick="CloseDetailsModal">✕</button>
            </div>
            <div class="modal-body">
                <table class="details-table">
                    <tr>
                        <td class="detail-lbl">العنوان</td>
                        <td class="fw-600">@selectedDoc.Title</td>
                    </tr>
                    <tr>
                        <td class="detail-lbl">نوع المستند</td>
                        <td><span class="badge badge-soft-blue">@selectedDoc.DocTypeDisplay</span></td>
                    </tr>
                    <tr>
                        <td class="detail-lbl">القضية</td>
                        <td>
                            @selectedDoc.CaseTitle
                            @if (!string.IsNullOrEmpty(selectedDoc.CaseNumber))
                            {
                                <span class="text-muted"> (@selectedDoc.CaseNumber)</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td class="detail-lbl">نوع الملف</td>
                        <td><span class="badge badge-outline-gray">@selectedDoc.FileExtension</span></td>
                    </tr>
                    <tr>
                        <td class="detail-lbl">حجم الملف</td>
                        <td>@selectedDoc.FileSizeDisplay</td>
                    </tr>
                    <tr>
                        <td class="detail-lbl">تاريخ الرفع</td>
                        <td>@selectedDoc.UploadedAt.ToString("yyyy/MM/dd — HH:mm")</td>
                    </tr>
                    <tr>
                        <td class="detail-lbl">رفع بواسطة</td>
                        <td>@selectedDoc.UploadedByName</td>
                    </tr>
                    @if (!string.IsNullOrEmpty(selectedDoc.Notes))
                    {
                        <tr>
                            <td class="detail-lbl">ملاحظات</td>
                            <td>@selectedDoc.Notes</td>
                        </tr>
                    }
                </table>
            </div>
            <div class="modal-actions">
                <button class="btn-secondary" @onclick="CloseDetailsModal">إغلاق</button>
                <a class="btn-primary"
                   href="@selectedDoc.FilePath.Replace("\\", "/")"
                   download="@(selectedDoc.Title + "." + selectedDoc.FileExtension.ToLower())">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                        <polyline points="7 10 12 15 17 10" />
                        <line x1="12" y1="15" x2="12" y2="3" />
                    </svg>
                    تحميل الملف
                </a>
            </div>
        </div>
    </div>
}


<!-- ══════════════════════════════════════════════════════════
     MODAL: تأكيد الحذف
     ══════════════════════════════════════════════════════════ -->
@if (showDeleteConfirm && docToDelete != null)
{
    <div class="modal-overlay" @onclick="CloseDeleteConfirm">
        <div class="modal-box" style="max-width:420px;" @onclick:stopPropagation="true" dir="rtl">
            <div class="modal-header" style="border-bottom:none;padding-bottom:.5rem;">
                <h3 class="modal-title" style="color:#dc2626;">تأكيد الحذف</h3>
                <button class="modal-close" @onclick="CloseDeleteConfirm" disabled="@isSaving">✕</button>
            </div>
            <div class="modal-body" style="text-align:center;padding:1rem 1.5rem 1.5rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="52" height="52" viewBox="0 0 24 24"
                     fill="none" stroke="#dc2626" stroke-width="1.5" style="margin-bottom:.75rem;">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="8" x2="12" y2="12" />
                    <line x1="12" y1="16" x2="12.01" y2="16" />
                </svg>
                <p style="color:#374151;margin:.25rem 0;">هل أنت متأكد من حذف المستند:</p>
                <p class="fw-600" style="font-size:1rem;margin:.4rem 0;">"@docToDelete.Title"</p>
                <p style="font-size:.82rem;color:#94a3b8;margin-top:.5rem;">
                    سيتم حذف الملف نهائياً ولا يمكن التراجع عن هذا الإجراء.
                </p>

                @if (!string.IsNullOrEmpty(deleteErrorMsg))
                {
                    <div class="error-msg" style="margin-top:.75rem;">⚠️ @deleteErrorMsg</div>
                }
            </div>
            <div class="modal-actions">
                <button class="btn-secondary" @onclick="CloseDeleteConfirm" disabled="@isSaving">إلغاء</button>
                <button class="btn-danger" @onclick="ConfirmDelete" disabled="@isSaving">
                    @(isSaving ? "جاري الحذف..." : "نعم، احذف")
                </button>
            </div>
        </div>
    </div>
}


<!-- ══════════════════════════════════════════════════════════
     Toast
     ══════════════════════════════════════════════════════════ -->
@if (!string.IsNullOrEmpty(toastMsg))
{
    <div class="doc-toast @(toastError ? "doc-toast-err" : "doc-toast-ok")">
        @toastMsg
    </div>
}


@code {
    // ── Data ─────────────────────────────────────────────────
    private List<DocumentListDto> allDocuments = new();
    private List<DocumentListDto> filteredDocuments = new();
    private DocumentStatsDto? stats;
    private List<CaseSummaryDto> allCases = new();

    // ── UI State ─────────────────────────────────────────────
    private bool isLoading = true;
    private bool isSaving = false;

    // ── Errors ───────────────────────────────────────────────
    private string loadErrorMsg = string.Empty;
    private string uploadErrorMsg = string.Empty;
    private string deleteErrorMsg = string.Empty;

    // ── Toast ────────────────────────────────────────────────
    private string toastMsg = string.Empty;
    private bool toastError = false;

    // ── Search ───────────────────────────────────────────────
    private string searchTerm = string.Empty;

    // ── Upload Modal ─────────────────────────────────────────
    private bool showUploadModal = false;
    private DocumentCreateDto uploadDto = new();
    private IBrowserFile? selectedFile = null;

    // ── Details Modal ────────────────────────────────────────
    private bool showDetailsModal = false;
    private DocumentListDto? selectedDoc = null;

    // ── Delete Confirm ───────────────────────────────────────
    private bool showDeleteConfirm = false;
    private DocumentListDto? docToDelete = null;

    // ═════════════════════════════════════════════════════════
    // Lifecycle
    // ═════════════════════════════════════════════════════════

    protected override async Task OnInitializedAsync()
        => await LoadDataAsync();

    // ═════════════════════════════════════════════════════════
    // Data Loading
    // ═════════════════════════════════════════════════════════

    private async Task LoadDataAsync()
    {
        isLoading = true;
        loadErrorMsg = string.Empty;
        StateHasChanged();
        try
        {
            allCases = await CaseService.GetAllCasesAsync();
            allDocuments = await DocumentService.GetAllDocumentsAsync();
            stats = await DocumentService.GetDocumentStatsAsync();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            loadErrorMsg = $"حدث خطأ أثناء تحميل البيانات: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void ApplyFilters()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredDocuments = allDocuments.ToList();
            return;
        }
        var t = searchTerm.Trim();
        filteredDocuments = allDocuments.Where(d =>
            d.Title.Contains(t, StringComparison.OrdinalIgnoreCase) ||
            d.CaseTitle.Contains(t, StringComparison.OrdinalIgnoreCase) ||
            d.CaseNumber.Contains(t, StringComparison.OrdinalIgnoreCase) ||
            d.DocTypeDisplay.Contains(t, StringComparison.OrdinalIgnoreCase)
        ).ToList();
    }

    // ═════════════════════════════════════════════════════════
    // Search
    // ═════════════════════════════════════════════════════════

    private void OnSearchChanged(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;
        ApplyFilters();
    }

    private void ClearSearch()
    {
        searchTerm = string.Empty;
        ApplyFilters();
    }

    // ═════════════════════════════════════════════════════════
    // Upload Modal
    // ═════════════════════════════════════════════════════════

    private void OpenUploadModal()
    {
        uploadDto = new DocumentCreateDto();
        selectedFile = null;
        uploadErrorMsg = string.Empty;
        showUploadModal = true;
    }

    private void CloseUploadModal()
    {
        if (isSaving) return;
        showUploadModal = false;
        selectedFile = null;
        uploadErrorMsg = string.Empty;
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        uploadErrorMsg = string.Empty;
        // تعبئة العنوان تلقائياً من اسم الملف إن كان فارغاً
        if (string.IsNullOrWhiteSpace(uploadDto.Title))
            uploadDto.Title = Path.GetFileNameWithoutExtension(e.File.Name);
    }

    private async Task SubmitUpload()
    {
        uploadErrorMsg = string.Empty;

        if (string.IsNullOrWhiteSpace(uploadDto.Title)) { uploadErrorMsg = "عنوان المستند مطلوب."; return; }
        if (uploadDto.CaseId <= 0) { uploadErrorMsg = "يجب اختيار القضية المرتبطة."; return; }
        if (selectedFile == null) { uploadErrorMsg = "يجب اختيار ملف للرفع."; return; }

        isSaving = true;
        StateHasChanged();
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (!int.TryParse(userClaim, out int userId) || userId == 0)
            {
                uploadErrorMsg = "لم يتم التعرف على المستخدم. يرجى تسجيل الدخول مجدداً.";
                return;
            }

            await DocumentService.UploadDocumentAsync(uploadDto, selectedFile, userId, GetWwwrootPath());

            showUploadModal = false;
            selectedFile = null;
            await LoadDataAsync();
            ShowToast("تم رفع المستند بنجاح ✓", false);
        }
        catch (InvalidOperationException ex) { uploadErrorMsg = ex.Message; }
        catch (Exception ex) { uploadErrorMsg = $"خطأ غير متوقع: {ex.Message}"; }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    // ═════════════════════════════════════════════════════════
    // Details Modal
    // ═════════════════════════════════════════════════════════

    private void OpenDetailsModal(DocumentListDto doc)
    {
        selectedDoc = doc;
        showDetailsModal = true;
    }

    private void CloseDetailsModal()
    {
        showDetailsModal = false;
        selectedDoc = null;
    }

    // ═════════════════════════════════════════════════════════
    // Delete
    // ═════════════════════════════════════════════════════════

    private void OpenDeleteConfirm(DocumentListDto doc)
    {
        docToDelete = doc;
        deleteErrorMsg = string.Empty;
        showDeleteConfirm = true;
    }

    private void CloseDeleteConfirm()
    {
        if (isSaving) return;
        showDeleteConfirm = false;
        docToDelete = null;
        deleteErrorMsg = string.Empty;
    }

    private async Task ConfirmDelete()
    {
        if (docToDelete == null) return;
        isSaving = true;
        deleteErrorMsg = string.Empty;
        StateHasChanged();
        try
        {
            await DocumentService.DeleteDocumentAsync(docToDelete.Id, GetWwwrootPath());
            showDeleteConfirm = false;
            docToDelete = null;
            await LoadDataAsync();
            ShowToast("تم حذف المستند بنجاح.", false);
        }
        catch (Exception ex) { deleteErrorMsg = $"حدث خطأ أثناء الحذف: {ex.Message}"; }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    // ═════════════════════════════════════════════════════════
    // Helpers
    // ═════════════════════════════════════════════════════════

    private static string GetWwwrootPath()
    {
        var appDir = AppDomain.CurrentDomain.BaseDirectory;
        var candidate = Path.Combine(appDir, "wwwroot");
        if (Directory.Exists(candidate)) return candidate;
        return Path.Combine(Directory.GetCurrentDirectory(), "wwwroot");
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }

    private static string GetExtClass(string ext) => ext.ToUpper() switch
    {
        "PDF" => "ext-pdf",
        "DOC" or "DOCX" => "ext-word",
        "XLS" or "XLSX" => "ext-excel",
        "PPT" or "PPTX" => "ext-ppt",
        "JPG" or "JPEG"
              or "PNG"
              or "GIF" => "ext-img",
        _ => "ext-other"
    };

    private async void ShowToast(string msg, bool isErr)
    {
        toastMsg = msg;
        toastError = isErr;
        StateHasChanged();
        await Task.Delay(3200);
        toastMsg = string.Empty;
        StateHasChanged();
    }
}


