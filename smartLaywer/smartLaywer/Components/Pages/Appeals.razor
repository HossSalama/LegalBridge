    <div class="tabs">
        <button class="tab tab-active">الكل (3)</button>
        <button class="tab">قيد النظر</button>
        <button class="tab">جاري</button>
        <button class="tab">مقبول</button>
        <button class="tab">مرفوض</button>
    </div>

    <!-- Appeals List -->
    <div class="appeals-list">

        <!-- Appeal 1 -->
        <div class="appeal-card">
            <div class="appeal-main">
                <div class="appeal-icon-wrap">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18" /><polyline points="17 6 23 6 23 12" /></svg>
                </div>
                <div class="appeal-content">
                    <div class="appeal-title-row">
                        <h3 class="appeal-number">APP-2024-001</h3>
                        <span class="badge badge-blue">جاري</span>
                        <span class="badge badge-red-soft">جنائي</span>
                    </div>
                    <div class="appeal-meta">
                        <span><span class="meta-label">العميل: </span>محمد حسن إبراهيم</span>
                        <span><span class="meta-label">القضية الأصلية: </span>2024/101</span>
                        <span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                            <span class="meta-label">تاريخ التقديم: </span>2024-03-01
                        </span>
                        <span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                            <span class="meta-label">موعد الجلسة: </span>2026-04-10
                        </span>
                        <span class="meta-full"><span class="meta-label">المحكمة: </span>محكمة الاستئناف العليا</span>
                    </div>
                    <div class="appeal-boxes">
                        <div class="info-box box-red">
                            <p class="box-label">الحكم الأصلي:</p>
                            <p class="box-text">الحكم بالسجن لمدة 3 سنوات</p>
                        </div>
                        <div class="info-box box-amber">
                            <p class="box-label">أسباب الطعن:</p>
                            <p class="box-text">الطعن على الحكم الصادر بالإدانة لعدم كفاية الأدلة</p>
                        </div>
                        <div class="info-box box-blue">
                            <p class="box-label">الطلبات:</p>
                            <p class="box-text">إلغاء الحكم أو تخفيف العقوبة</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="appeal-actions">
                <button class="btn-outline btn-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
                    عرض التفاصيل
                </button>
                <button class="btn-outline btn-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                    المذكرات
                </button>
                <button class="btn-outline btn-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
                    تحميل
                </button>
            </div>
        </div>

        <!-- Appeal 2 -->
        <div class="appeal-card">
            <div class="appeal-main">
                <div class="appeal-icon-wrap">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18" /><polyline points="17 6 23 6 23 12" /></svg>
                </div>
                <div class="appeal-content">
                    <div class="appeal-title-row">
                        <h3 class="appeal-number">APP-2024-002</h3>
                        <span class="badge badge-amber">قيد النظر</span>
                        <span class="badge badge-blue-soft">مدني</span>
                    </div>
                    <div class="appeal-meta">
                        <span><span class="meta-label">العميل: </span>أحمد محمود عبد الله</span>
                        <span><span class="meta-label">القضية الأصلية: </span>2024/156</span>
                        <span><span class="meta-label">تاريخ التقديم: </span>2024-03-15</span>
                        <span><span class="meta-label">موعد الجلسة: </span>2026-04-15</span>
                        <span class="meta-full"><span class="meta-label">المحكمة: </span>محكمة الاستئناف المدنية</span>
                    </div>
                    <div class="appeal-boxes">
                        <div class="info-box box-red">
                            <p class="box-label">الحكم الأصلي:</p>
                            <p class="box-text">الحكم بدفع تعويض 100,000 جنيه</p>
                        </div>
                        <div class="info-box box-amber">
                            <p class="box-label">أسباب الطعن:</p>
                            <p class="box-text">الطعن على حكم التعويضات المالية</p>
                        </div>
                        <div class="info-box box-blue">
                            <p class="box-label">الطلبات:</p>
                            <p class="box-text">إلغاء الحكم أو تخفيض التعويض</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="appeal-actions">
                <button class="btn-outline btn-sm">عرض التفاصيل</button>
                <button class="btn-outline btn-sm">المذكرات</button>
                <button class="btn-outline btn-sm">تحميل</button>
            </div>
        </div>

        <!-- Appeal 3 -->
        <div class="appeal-card">
            <div class="appeal-main">
                <div class="appeal-icon-wrap">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18" /><polyline points="17 6 23 6 23 12" /></svg>
                </div>
                <div class="appeal-content">
                    <div class="appeal-title-row">
                        <h3 class="appeal-number">APP-2024-003</h3>
                        <span class="badge badge-green">مقبول</span>
                        <span class="badge badge-green-soft">إداري</span>
                    </div>
                    <div class="appeal-meta">
                        <span><span class="meta-label">العميل: </span>فاطمة حسن علي</span>
                        <span><span class="meta-label">القضية الأصلية: </span>2023/289</span>
                        <span><span class="meta-label">تاريخ التقديم: </span>2024-02-20</span>
                        <span><span class="meta-label">موعد الجلسة: </span>2026-04-05</span>
                        <span class="meta-full"><span class="meta-label">المحكمة: </span>المحكمة الإدارية العليا</span>
                    </div>
                    <div class="appeal-boxes">
                        <div class="info-box box-red">
                            <p class="box-label">الحكم الأصلي:</p>
                            <p class="box-text">رفض الطعن الإداري</p>
                        </div>
                        <div class="info-box box-amber">
                            <p class="box-label">أسباب الطعن:</p>
                            <p class="box-text">الطعن على قرار إداري</p>
                        </div>
                        <div class="info-box box-blue">
                            <p class="box-label">الطلبات:</p>
                            <p class="box-text">إلغاء القرار الإداري</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="appeal-actions">
                <button class="btn-outline btn-sm">عرض التفاصيل</button>
                <button class="btn-outline btn-sm">المذكرات</button>
                <button class="btn-outline btn-sm">تحميل</button>
            </div>
        </div>

    </div>
</div>

<style>
    .appeals-page {
        padding: 1.5rem;
        font-family: 'Segoe UI',Tahoma,sans-serif;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .page-header-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: .75rem;
    }

    .page-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1e293b;
        margin: 0;
    }

    .page-sub {
        color: #64748b;
        margin: .25rem 0 0;
    }

    /* Stats */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(180px,1fr));
        gap: 1rem;
    }

    .stat-card {
        background: #fff;
        border-radius: 12px;
        padding: 1.25rem;
        box-shadow: 0 1px 6px rgba(0,0,0,.08);
    }

    .stat-body {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .stat-label {
        font-size: .85rem;
        color: #64748b;
        margin: 0;
    }

    .stat-value {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1e293b;
        margin: .2rem 0 0;
    }

        .stat-value.amber {
            color: #d97706;
        }

        .stat-value.green {
            color: #16a34a;
        }

        .stat-value.red {
            color: #dc2626;
        }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        flex-shrink: 0;
    }

    .bg-blue {
        background: #2563eb;
    }

    .bg-amber {
        background: #d97706;
    }

    .bg-green {
        background: #16a34a;
    }

    .bg-red {
        background: #dc2626;
    }

    /* Search */
    .search-row {
        display: flex;
        gap: 1rem;
    }

    .search-box {
        flex: 1;
        position: relative;
    }

    .search-icon {
        position: absolute;
        right: .75rem;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
    }

    .search-input {
        width: 100%;
        padding: .6rem .6rem .6rem 2.2rem;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: .9rem;
        outline: none;
        box-sizing: border-box;
    }

        .search-input:focus {
            border-color: #d97706;
        }

    /* Tabs */
    .tabs {
        display: flex;
        gap: .25rem;
        background: #f8fafc;
        border-radius: 10px;
        padding: .3rem;
        width: fit-content;
    }

    .tab {
        padding: .45rem 1rem;
        border: none;
        background: transparent;
        border-radius: 8px;
        font-size: .85rem;
        cursor: pointer;
        color: #64748b;
        transition: all .2s;
        white-space: nowrap;
    }

    .tab-active {
        background: #fff;
        color: #d97706;
        font-weight: 600;
        box-shadow: 0 1px 4px rgba(0,0,0,.08);
    }

    /* Appeals List */
    .appeals-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .appeal-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 1px 6px rgba(0,0,0,.08);
        padding: 1.5rem;
        display: flex;
        justify-content: space-between;
        gap: 1rem;
    }

    .appeal-main {
        display: flex;
        gap: 1rem;
        flex: 1;
    }

    .appeal-icon-wrap {
        width: 48px;
        height: 48px;
        border-radius: 10px;
        background: #fef3c7;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #d97706;
        flex-shrink: 0;
    }

    .appeal-content {
        flex: 1;
    }

    .appeal-title-row {
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .75rem;
        flex-wrap: wrap;
    }

    .appeal-number {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1e293b;
        margin: 0;
    }

    .appeal-meta {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .4rem .75rem;
        font-size: .85rem;
        color: #475569;
        margin-bottom: 1rem;
    }

    .meta-label {
        color: #94a3b8;
    }

    .meta-full {
        grid-column: 1/-1;
    }

    .appeal-boxes {
        display: flex;
        flex-direction: column;
        gap: .5rem;
    }

    .info-box {
        padding: .6rem .85rem;
        border-radius: 8px;
    }

    .box-red {
        background: #fff1f2;
        border: 1px solid #fecdd3;
    }

    .box-amber {
        background: #fffbeb;
        border: 1px solid #fde68a;
    }

    .box-blue {
        background: #eff6ff;
        border: 1px solid #bfdbfe;
    }

    .box-label {
        font-size: .75rem;
        font-weight: 600;
        margin: 0 0 .2rem;
    }

    .box-red .box-label {
        color: #9f1239;
    }

    .box-amber .box-label {
        color: #92400e;
    }

    .box-blue .box-label {
        color: #1e40af;
    }

    .box-text {
        font-size: .85rem;
        margin: 0;
    }

    .box-red .box-text {
        color: #be123c;
    }

    .box-amber .box-text {
        color: #b45309;
    }

    .box-blue .box-text {
        color: #1d4ed8;
    }

    .appeal-actions {
        display: flex;
        flex-direction: column;
        gap: .5rem;
        min-width: 110px;
    }

    /* Badges */
    .badge {
        font-size: .72rem;
        padding: .2rem .6rem;
        border-radius: 999px;
        font-weight: 600;
    }

    .badge-blue {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .badge-blue-soft {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .badge-amber {
        background: #fef3c7;
        color: #d97706;
    }

    .badge-green {
        background: #dcfce7;
        color: #15803d;
    }

    .badge-green-soft {
        background: #dcfce7;
        color: #15803d;
    }

    .badge-red-soft {
        background: #fee2e2;
        color: #dc2626;
    }

    /* Buttons */
    .btn-primary {
        background: #d97706;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: .55rem 1.1rem;
        font-size: .9rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .4rem;
        transition: background .2s;
    }

        .btn-primary:hover {
            background: #b45309;
        }

    .btn-outline {
        background: transparent;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: .45rem .9rem;
        font-size: .85rem;
        cursor: pointer;
        color: #475569;
        display: flex;
        align-items: center;
        gap: .35rem;
        transition: all .2s;
        white-space: nowrap;
    }

        .btn-outline:hover {
            border-color: #d97706;
            color: #d97706;
        }

    .btn-sm {
        padding: .35rem .7rem;
        font-size: .8rem;
    }
</style>
