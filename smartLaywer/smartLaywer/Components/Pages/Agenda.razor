@page "/agenda"
@namespace smartLaywer.Components.Pages
@using smartLaywer.DTO.Agenda
@using smartLaywer.Enum
@using smartLaywer.Models
@inject IAgendaService AgendaService
@inject ILookupService LookupService

<PageTitle>الأجندة القضائية</PageTitle>

<div class="agenda-page" dir="rtl">

    <!-- ══════════════════ HEADER ══════════════════ -->
    <div class="page-header-row">
        <div>
            <h1 class="page-title">الأجندة القضائية</h1>
            <p class="page-sub">جدولة ومتابعة جميع المواعيد والجلسات</p>
        </div>
        <button class="btn-primary" @onclick="OpenAddModal">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            إضافة موعد
        </button>
    </div>

    <!-- ══════════════════ STATS ══════════════════ -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-body">
                <div>
                    <p class="stat-label">مواعيد اليوم</p>
                    <h3 class="stat-value">@(stats?.TodayCount ?? 0)</h3>
                </div>
                <div class="stat-icon bg-blue">@((MarkupString)Ico22Cal)</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-body">
                <div>
                    <p class="stat-label">هذا الأسبوع</p>
                    <h3 class="stat-value">@(stats?.WeekCount ?? 0)</h3>
                </div>
                <div class="stat-icon bg-green">@((MarkupString)Ico22Clock)</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-body">
                <div>
                    <p class="stat-label">جلسات قادمة</p>
                    <h3 class="stat-value blue">@(stats?.UpcomingHearingsCount ?? 0)</h3>
                </div>
                <div class="stat-icon bg-blue">@((MarkupString)Ico22Brief)</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-body">
                <div>
                    <p class="stat-label">مواعيد نهائية</p>
                    <h3 class="stat-value red">@(stats?.DeadlinesCount ?? 0)</h3>
                </div>
                <div class="stat-icon bg-red">@((MarkupString)Ico22File)</div>
            </div>
        </div>
    </div>

    <!-- ══════════════════ MAIN GRID ══════════════════ -->
    <div class="main-grid">

        <!-- Calendar -->
        <div class="card">
            <div class="card-header-plain">
                <h2 class="card-title">التقويم</h2>
            </div>
            <div class="card-body">
                <div class="cal-nav">
                    <button class="cal-nav-btn" @onclick="PrevMonth">‹</button>
                    <span class="cal-month">@GetMonthLabel(calYear, calMonth)</span>
                    <button class="cal-nav-btn" @onclick="NextMonth">›</button>
                </div>
                <div class="cal-grid">
                    <div class="cal-dow">أح</div><div class="cal-dow">إث</div>
                    <div class="cal-dow">ث</div><div class="cal-dow">أر</div>
                    <div class="cal-dow">خ</div><div class="cal-dow">ج</div>
                    <div class="cal-dow">س</div>

                    @{
                        var firstDay = (int)new DateTime(calYear, calMonth, 1).DayOfWeek;
                    }
                    @for (int i = 0; i < firstDay; i++)
                    {
                        <div class="cal-day cal-empty"></div>
                    }
                    @{
                        var daysInMonth = DateTime.DaysInMonth(calYear, calMonth);
                    }
                    @for (int d = 1; d <= daysInMonth; d++)
                    {
                        var day = d;
                        var thisDate = new DateTime(calYear, calMonth, day);
                        var isToday = thisDate.Date == DateTime.Today;
                        var isSelected = thisDate.Date == selectedDate?.Date;
                        var hasEvent = eventDates.Contains(thisDate.Date);
                        <div class="cal-day @(isToday ? "cal-today" : "") @(isSelected && !isToday ? "cal-selected" : "") @(hasEvent ? "cal-has-event" : "")"
                             @onclick="() => SelectDate(thisDate)">
                            @day
                            @if (hasEvent)
                            {
                                <span class="cal-dot @(isToday ? "dot-white" : "")"></span>
                            }
                        </div>
                    }
                </div>
                <div class="legend">
                    <div class="legend-item"><span class="legend-dot dot-blue"></span>جلسات محكمة</div>
                    <div class="legend-item"><span class="legend-dot dot-green"></span>اجتماعات</div>
                    <div class="legend-item"><span class="legend-dot dot-red"></span>مواعيد نهائية</div>
                    <div class="legend-item"><span class="legend-dot dot-amber"></span>جلسات تحقيق</div>
                </div>
            </div>
        </div>

        <!-- Events List -->
        <div class="card">
            <div class="card-header-row">
                <h2 class="card-title">
                    @if (selectedDate.HasValue)
                    {
                        <span>مواعيد @selectedDate.Value.ToString("yyyy-MM-dd")</span>
                    }
                    else
                    {

                        <span>المواعيد القادمة</span>
                    }
                </h2>
                @if (selectedDate.HasValue)
                {
                    <button class="btn-link" @onclick="ClearDateFilter">← عرض الكل</button>
                }
            </div>
            <div class="card-body">
                @if (isLoading)
                {
                    <div class="loading-msg">جاري التحميل...</div>
                }
                else if (!string.IsNullOrEmpty(loadError))
                {
                    <div class="error-msg" @onclick="() => loadError = string.Empty" style="cursor:pointer">
                        ⚠️ @loadError <small>(اضغط للإغلاق)</small>
                    </div>
                }
                else if (displayedItems.Count == 0)
                {
                    <div class="empty-msg">
                        @((MarkupString)Ico22Cal)
                        <p>لا توجد مواعيد في هذه الفترة</p>
                    </div>
                }
                else
                {
                    <div class="events-list">
                        @foreach (var item in displayedItems)
                        {
                            <div class="event-item event-@item.TypeColor">
                                <div class="event-main">
                                    <div class="event-icon">
                                        @if (item.ItemType == AgendaItemType.Hearing)
                                        {
                                            @((MarkupString)Ico20Cal)
                                        }
                                        else if (item.AppointmentType == AppointmentTypeEnum.MemoDeadline
                                        || item.AppointmentType == AppointmentTypeEnum.Deadline)
                                        {
                                            @((MarkupString)Ico20File)
                                        }
                                        else
                                        {
                                            @((MarkupString)Ico20Clock)
                                        }
                                    </div>
                                    <div class="event-content">
                                        <div class="event-title-row">
                                            <h4 class="event-title">@item.Title</h4>
                                            <span class="badge badge-outline">@item.TypeLabel</span>
                                            @if (item.IsHighPriority)
                                            {
                                                <span class="badge badge-red">أولوية عالية</span>
                                            }
                                            @if (item.IsCompleted)
                                            {
                                                <span class="badge badge-green">✓ مكتمل</span>
                                            }
                                        </div>
                                        <div class="event-meta">
                                            <span>@((MarkupString)IcoSmCal) @item.DateTime.ToString("yyyy-MM-dd")</span>
                                            <span>@((MarkupString)IcoSmClock) @item.DateTime.ToString("hh:mm tt")</span>
                                            @if (!string.IsNullOrEmpty(item.Location))
                                            {
                                                <span>@((MarkupString)IcoSmPin) @item.Location</span>
                                            }
                                            @if (!string.IsNullOrEmpty(item.CaseNumber))
                                            {
                                                <span>@((MarkupString)IcoSmFile) القضية: @item.CaseNumber</span>
                                            }
                                            @if (!string.IsNullOrEmpty(item.ClientName))
                                            {
                                                <span>@((MarkupString)IcoSmUser) @item.ClientName</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <div class="event-actions">
                                    <button class="btn-outline btn-sm" @onclick="() => OpenDetails(item)">
                                        التفاصيل
                                    </button>
                                    @if (item.ItemType == AgendaItemType.Appointment)
                                    {
                                        <button class="btn-primary btn-sm" @onclick="() => OpenEditModal(item)">
                                            تعديل
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- ══════════════════ ADD MODAL ══════════════════ -->
@if (showAddModal)
{
    <div class="modal-overlay" @onclick="CloseAddModal">
        <div class="modal-box modal-md" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3 class="modal-title">إضافة موعد جديد</h3>
                <button class="modal-close" @onclick="CloseAddModal">✕</button>
            </div>
            <p class="modal-sub">أدخل تفاصيل الموعد الجديد</p>
            <div class="modal-body">

                <div class="form-group">
                    <label>عنوان الموعد *</label>
                    <input type="text" class="form-input"
                           placeholder="مثال: اجتماع مع العميل / موعد تسليم المذكرة"
                           @bind="newAppt.Title" />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>نوع الموعد *</label>
                        <select class="form-input" @bind="newAppt.AppointmentType">
                            <option value="@AppointmentTypeEnum.ClientMeeting">اجتماع مع العميل</option>
                            <option value="@AppointmentTypeEnum.MemoDeadline">موعد تسليم المذكرة</option>
                            <option value="@AppointmentTypeEnum.Internal">موعد داخلي</option>
                            <option value="@AppointmentTypeEnum.Deadline">موعد نهائي</option>
                            <option value="@AppointmentTypeEnum.FollowUp">متابعة</option>
                            <option value="@AppointmentTypeEnum.Other">أخرى</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>الأولوية</label>
                        <select class="form-input" @bind="newAppt.Priority">
                            <option value="@AppointmentPriorityEnum.Normal">عادي</option>
                            <option value="@AppointmentPriorityEnum.High">مرتفع</option>
                            <option value="@AppointmentPriorityEnum.Urgent">عاجل</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>التاريخ والوقت *</label>
                        <input type="datetime-local" class="form-input"
                               value="@newAppt.AppointmentDate.ToString("yyyy-MM-ddTHH:mm")"
                               @onchange="e => { if (DateTime.TryParse(e.Value?.ToString(), out var d)) newAppt.AppointmentDate = d; }" />
                    </div>
                    <div class="form-group">
                        <label>المكان</label>
                        <input type="text" class="form-input"
                               placeholder="مثال: المكتب - غرفة الاجتماعات"
                               @bind="newAppt.Location" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>القضية المرتبطة</label>
                        <select class="form-input" @bind="selectedCaseId">
                            <option value="0">-- اختر قضية (اختياري) --</option>
                            @foreach (var c in availableCases)
                            {
                                <option value="@c.Id">@c.CaseNumber — @c.Title</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>العميل المرتبط</label>
                        <select class="form-input" @bind="selectedClientId">
                            <option value="0">-- اختر عميل (اختياري) --</option>
                            @foreach (var cl in availableClients)
                            {
                                <option value="@cl.Id">@cl.FullName</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>وصف / ملاحظات</label>
                    <textarea class="form-input" rows="3"
                              placeholder="تفاصيل إضافية..."
                              @bind="newAppt.Description"></textarea>
                </div>

                @if (!string.IsNullOrEmpty(addError))
                {
                    <div class="error-msg">@addError</div>
                }

                <div class="modal-actions">
                    <button class="btn-primary" style="flex:1"
                            @onclick="SaveAppointment" disabled="@isSaving">
                        @(isSaving ? "جاري الحفظ..." : "حفظ الموعد")
                    </button>
                    <button class="btn-outline" style="flex:1" @onclick="CloseAddModal">إلغاء</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- ══════════════════ DETAILS MODAL ══════════════════ -->
@if (showDetailsModal && detailsItem != null)
{
    <div class="modal-overlay" @onclick="() => showDetailsModal = false">
        <div class="modal-box modal-md" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3 class="modal-title">
                    @(detailsItem.ItemType == AgendaItemType.Hearing ? "تفاصيل الجلسة" : "تفاصيل الموعد")
                </h3>
                <button class="modal-close" @onclick="() => showDetailsModal = false">✕</button>
            </div>
            <div class="modal-body">
                <div class="detail-grid">

                    <div class="detail-item">
                        <span class="detail-label">العنوان</span>
                        <span class="detail-value">@detailsItem.Title</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">النوع</span>
                        <span class="detail-value">@detailsItem.TypeLabel</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">التاريخ والوقت</span>
                        <span class="detail-value">@detailsItem.DateTime.ToString("yyyy-MM-dd   hh:mm tt")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">المكان</span>
                        <span class="detail-value">@(string.IsNullOrEmpty(detailsItem.Location) ? "—" : detailsItem.Location)</span>
                    </div>

                    @if (!string.IsNullOrEmpty(detailsItem.CaseNumber))
                    {
                        <div class="detail-item">
                            <span class="detail-label">رقم القضية</span>
                            <span class="detail-value">@detailsItem.CaseNumber</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(detailsItem.ClientName))
                    {
                        <div class="detail-item">
                            <span class="detail-label">العميل</span>
                            <span class="detail-value">@detailsItem.ClientName</span>
                        </div>
                    }

                    @if (detailsItem.ItemType == AgendaItemType.Hearing)
                    {
                        <div class="detail-item">
                            <span class="detail-label">المحكمة</span>
                            <span class="detail-value">@(detailsItem.CourtName ?? "—")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">الدائرة</span>
                            <span class="detail-value">@(detailsItem.DepartmentName ?? "—")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">القاضي</span>
                            <span class="detail-value">@(string.IsNullOrEmpty(detailsItem.JudgeName) ? "—" : detailsItem.JudgeName)</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">حالة الحضور</span>
                            <span class="detail-value">@(detailsItem.AttendanceStatus?.GetDisplayName() ?? "—")</span>
                        </div>
                        <div class="detail-item" style="grid-column:span 2">
                            <span class="detail-label">النتيجة</span>
                            <span class="detail-value">@(string.IsNullOrEmpty(detailsItem.Result) ? "لم تُحدَّد بعد" : detailsItem.Result)</span>
                        </div>
                    }
                    else
                    {
                        <div class="detail-item">
                            <span class="detail-label">الأولوية</span>
                            <span class="detail-value">@(detailsItem.PriorityLabel ?? "—")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">الحالة</span>
                            <span class="detail-value">@(detailsItem.IsCompleted ? "✓ مكتمل" : "قادم")</span>
                        </div>
                        @if (!string.IsNullOrEmpty(detailsItem.Description))
                        {
                            <div class="detail-item" style="grid-column:span 2">
                                <span class="detail-label">الوصف / الملاحظات</span>
                                <span class="detail-value">@detailsItem.Description</span>
                            </div>
                        }
                    }

                    <div class="detail-item">
                        <span class="detail-label">أُضيف بواسطة</span>
                        <span class="detail-value">@(detailsItem.CreatedByName ?? "—")</span>
                    </div>

                </div>
                <div class="modal-actions" style="margin-top:1rem">
                    <button class="btn-outline" style="flex:1"
                            @onclick="() => showDetailsModal = false">
                        إغلاق
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- ══════════════════ EDIT MODAL ══════════════════ -->
