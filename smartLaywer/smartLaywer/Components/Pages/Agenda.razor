                        <select class="form-input" @bind="editAppt.AppointmentType">
                            <option value="@AppointmentTypeEnum.ClientMeeting">اجتماع مع العميل</option>
                            <option value="@AppointmentTypeEnum.MemoDeadline">موعد تسليم المذكرة</option>
                            <option value="@AppointmentTypeEnum.Internal">موعد داخلي</option>
                            <option value="@AppointmentTypeEnum.Deadline">موعد نهائي</option>
                            <option value="@AppointmentTypeEnum.FollowUp">متابعة</option>
                            <option value="@AppointmentTypeEnum.Other">أخرى</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>الأولوية</label>
                        <select class="form-input" @bind="editAppt.Priority">
                            <option value="@AppointmentPriorityEnum.Normal">عادي</option>
                            <option value="@AppointmentPriorityEnum.High">مرتفع</option>
                            <option value="@AppointmentPriorityEnum.Urgent">عاجل</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>التاريخ والوقت *</label>
                        <input type="datetime-local" class="form-input"
                               value="@editAppt!.AppointmentDate.ToString("yyyy-MM-ddTHH:mm")"
                               @onchange="e => { if (DateTime.TryParse(e.Value?.ToString(), out var d)) editAppt!.AppointmentDate = d; }" />
                    </div>
                    <div class="form-group">
                        <label>المكان</label>
                        <input type="text" class="form-input"
                               placeholder="مثال: المكتب - غرفة الاجتماعات"
                               @bind="editAppt.Location" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>القضية المرتبطة</label>
                        <select class="form-input" @bind="editCaseId">
                            <option value="0">-- اختر قضية (اختياري) --</option>
                            @foreach (var c in availableCases)
                            {
                                <option value="@c.Id">@c.CaseNumber — @c.Title</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>العميل المرتبط</label>
                        <select class="form-input" @bind="editClientId">
                            <option value="0">-- اختر عميل (اختياري) --</option>
                            @foreach (var cl in availableClients)
                            {
                                <option value="@cl.Id">@cl.FullName</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>وصف / ملاحظات</label>
                    <textarea class="form-input" rows="3"
                              placeholder="تفاصيل إضافية..."
                              @bind="editAppt.Description"></textarea>
                </div>

                @if (!string.IsNullOrEmpty(editError))
                {
                    <div class="error-msg">@editError</div>
                }

                <div class="modal-actions">
                    <button class="btn-primary" style="flex:1"
                            @onclick="SaveEdit" disabled="@isSaving">
                        @(isSaving ? "جاري الحفظ..." : "حفظ التعديل")
                    </button>
                    <button class="btn-outline" style="flex:1" @onclick="CloseEditModal">إلغاء</button>
                </div>
            </div>
        </div>
    </div>
}

@code {


    private List<AgendaItemDto> allItems = new();
    private List<AgendaItemDto> displayedItems = new();
    private AgendaStatsDto? stats;
    private HashSet<DateTime> eventDates = new();

    private List<Case> availableCases = new();
    private List<Client> availableClients = new();

    private int selectedCaseId = 0;
    private int selectedClientId = 0;

    private int calYear = DateTime.Today.Year;
    private int calMonth = DateTime.Today.Month;
    private DateTime? selectedDate;

    private int currentUserId = 0;

    private bool isLoading = true;
    private bool isSaving = false;
    private string loadError = string.Empty;
    private string addError = string.Empty;

    private bool showAddModal = false;
    private AppointmentCreationDto newAppt = new();

    private bool showDetailsModal = false;
    private AgendaItemDto? detailsItem;

    private bool showEditModal = false;
    private AppointmentCreationDto? editAppt;
    private int editAppointmentId = 0;
    private int editCaseId = 0;
    private int editClientId = 0;
    private string editError = string.Empty;

    private bool showDeleteConfirm = false;
    private int deleteTargetId = 0;

    protected override async Task OnInitializedAsync()
    {
        var stored = await SecureStorage.Default.GetAsync("UserId");
        if (int.TryParse(stored, out var uid))
            currentUserId = uid;

        await LoadAllAsync();
    }

    private async Task LoadAllAsync()
    {
        isLoading = true;
        loadError = string.Empty;
        StateHasChanged();
        try
        {
            stats = await AgendaService.GetAgendaStatsAsync();
            allItems = await AgendaService.GetUpcomingItemsAsync(60);
            availableClients = await LookupService.GetActiveClientsAsync();
            availableCases = await LookupService.GetActiveCasesAsync();
            await RefreshCalendarDots();

            ApplyFilter();
        }
        catch (Exception ex)
        {
            loadError = $"حدث خطأ أثناء تحميل البيانات: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task RefreshCalendarDots()
    {
        var dates = await AgendaService.GetDatesWithEventsAsync(calYear, calMonth);
        eventDates = dates.ToHashSet();
    }

    private void ApplyFilter()
    {
        displayedItems = selectedDate.HasValue
            ? allItems.Where(i => i.DateTime.Date == selectedDate.Value.Date).ToList()
            : allItems;
    }

    
    private void SelectDate(DateTime date)
    {
        selectedDate = date;
        ApplyFilter();
    }

    private void ClearDateFilter()
    {
        selectedDate = null;
        ApplyFilter();
    }

    private async Task PrevMonth()
    {
        var dt = new DateTime(calYear, calMonth, 1).AddMonths(-1);
        calYear = dt.Year;
        calMonth = dt.Month;
        await RefreshCalendarDots();
    }

    private async Task NextMonth()
    {
        var dt = new DateTime(calYear, calMonth, 1).AddMonths(1);
        calYear = dt.Year;
        calMonth = dt.Month;
        await RefreshCalendarDots();
    }

    private static string GetMonthLabel(int year, int month)
    {
        string[] ar = { "يناير","فبراير","مارس","أبريل","مايو","يونيو",
                         "يوليو","أغسطس","سبتمبر","أكتوبر","نوفمبر","ديسمبر" };
        return $"{ar[month - 1]} {year}";
    }

    
    private void OpenAddModal()
    {
        newAppt = new AppointmentCreationDto
        {
            AppointmentDate = DateTime.Now.AddHours(1),
            AppointmentType = AppointmentTypeEnum.ClientMeeting,
            Priority = AppointmentPriorityEnum.Normal,
            CreatedBy = currentUserId
        };
        selectedCaseId = 0;
        selectedClientId = 0;
        addError = string.Empty;
        showAddModal = true;
    }

    private void CloseAddModal()
    {
        showAddModal = false;
        addError = string.Empty;
    }

    private async Task SaveAppointment()
    {
        addError = string.Empty;

        if (newAppt.AppointmentDate == default || newAppt.AppointmentDate < DateTime.Now.AddMinutes(-5))
        { addError = "يجب اختيار تاريخ ووقت صحيح ."; return; }
        if (string.IsNullOrWhiteSpace(newAppt.Title))
        { addError = "عنوان الموعد مطلوب."; return; }

        if (newAppt.AppointmentDate < DateTime.Now.AddMinutes(-5))
        { addError = "تاريخ الموعد يجب أن يكون في المستقبل."; return; }

        if (currentUserId == 0)
        { addError = "يجب تسجيل الدخول أولاً."; return; }

        newAppt.CaseId = selectedCaseId == 0 ? null : selectedCaseId;
        newAppt.ClientId = selectedClientId == 0 ? null : selectedClientId;
        newAppt.CreatedBy = currentUserId;

        isSaving = true;
        try
        {
            var ok = await AgendaService.AddAppointmentAsync(newAppt);
            if (ok)
            {
                CloseAddModal();
                await LoadAllAsync();
            }
            else
            {
                addError = "فشل حفظ الموعد. حاول مرة أخرى.";
            }
        }
        catch (Exception ex)
        {
            addError = $"خطأ: {ex.Message}";
        }
        finally { isSaving = false; }
    }

    
    private void OpenDetails(AgendaItemDto item)
    {
        detailsItem = item;
        showDetailsModal = true;
    }


    private void OpenEditModal(AgendaItemDto item)
    {
        editAppointmentId = item.Id;
        editAppt = new AppointmentCreationDto
        {
            Title = item.Title,
            Description = item.Description,
            AppointmentDate = item.DateTime == default ? DateTime.Now.AddHours(1) : item.DateTime,
            AppointmentType = item.AppointmentType ?? AppointmentTypeEnum.ClientMeeting,
            Priority = item.Priority ?? AppointmentPriorityEnum.Normal,
            Location = item.Location,
            CreatedBy = currentUserId
        };
        editCaseId = availableCases.FirstOrDefault(c => c.CaseNumber == item.CaseNumber)?.Id ?? 0;
        editClientId = availableClients.FirstOrDefault(c => c.FullName == item.ClientName)?.Id ?? 0;
        editError = string.Empty;
        showEditModal = true;
    }

    private void CloseEditModal()
    {
        showEditModal = false;
        editAppt = null;
        editError = string.Empty;
    }

    private async Task SaveEdit()
    {
        if (editAppt == null) return;
        editError = string.Empty;

        if (string.IsNullOrWhiteSpace(editAppt.Title))
        { editError = "عنوان الموعد مطلوب."; return; }

        if (editAppt.AppointmentDate == default)
        { editError = "يجب اختيار تاريخ ووقت صحيح."; return; }

        editAppt.CaseId = editCaseId == 0 ? null : editCaseId;
        editAppt.ClientId = editClientId == 0 ? null : editClientId;
        editAppt.CreatedBy = currentUserId;

        isSaving = true;
        try
        {
            var ok = await AgendaService.UpdateAppointmentAsync(editAppointmentId, editAppt);
            if (ok)
            {
                CloseEditModal();
                await LoadAllAsync();
            }
            else
            {
                editError = "فشل حفظ التعديل. حاول مرة أخرى.";
            }
        }
        catch (Exception ex)
        {
            editError = $"خطأ: {ex.Message}";
        }
        finally { isSaving = false; }
    }



