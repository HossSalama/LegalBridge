}

@code {
    private FinancialStatDto stats = new(); 
    private bool isLoading = true;
    private List<FeeDetailsDto> fees;
    private string searchTerm = "";
    private int currentPage = 1;
    private bool hasNextPage; 
    private bool hasPreviousPage;
    private int totalPages;
    private bool showScheduleModal = false;
    private string selectedCaseNumber = "";
    private int selectedFeeId;
    private decimal selectedRemainingAmount;
    private List<NewScheduleItem> newSchedulesList = new();
    private decimal currentTotalNewSchedules => newSchedulesList.Sum(s => s.Amount);
    private bool showModal = false; 
    private PaymentDto paymentDto = new();
    public class NewScheduleItem
    {
        public decimal Amount { get; set; }
        public DateTime DueDate { get; set; } = DateTime.Now.AddMonths(1);
    }
    public class PaymentDto
    {
        public decimal Amount { get; set; }
        public DateTime PaymentDate { get; set; } = DateTime.Now;
        public PaymentMethodEnum PaymentMethod { get; set; } = PaymentMethodEnum.Cash; // «ð —«÷Ì ‰Þœ«
    }
    private void OpenPaymentModal(int feeId)
    {
        selectedFeeId = feeId;
        paymentDto = new PaymentDto(); // ≈⁄«œ…  ’ðÌ— «·»Ì«‰« 
        showModal = true;
    }
    private void CloseModal() => showModal = false;
    private async Task HandlePaymentSubmit()
    {
        if (paymentDto.Amount <= 0) return;

        isLoading = true;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (int.TryParse(userIdClaim, out int currentUserId))
        {
            var success = await FinancialsService.CollectPaymentAsync(
                selectedFeeId,
                paymentDto.Amount,
                paymentDto.PaymentMethod,
                currentUserId
            );

            if (success)
            {
                showModal = false;
                await LoadDashboardStats();
                await LoadFees();
            }
            else
            {
                // „„þ‰  ÷Ìð Â‰« Alert ··„” Œœ„ ·Ê «·ð‘· »”»» «·œ« «»Ì“
                Console.WriteLine("ð‘· ðÌ  ”ÃÌ· ⁄„·Ì… «·œð⁄.");
            }
        }

        isLoading = false;
    }
    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardStats();
        await LoadFees();
    }
    private void OpenScheduleModal(int feeId, string caseNumber, decimal remainingAmount)
    {
        selectedFeeId = feeId;
        selectedCaseNumber = caseNumber;
        selectedRemainingAmount = remainingAmount;

        newSchedulesList.Clear(); 
        AddScheduleRow(); 

        showScheduleModal = true;
    }
    private void AddScheduleRow()
    {
        decimal suggestedAmount = selectedRemainingAmount - currentTotalNewSchedules;
        if (suggestedAmount < 0) suggestedAmount = 0;

        newSchedulesList.Add(new NewScheduleItem { Amount = suggestedAmount });
    }

    private void RemoveScheduleRow(NewScheduleItem item)
    {
        newSchedulesList.Remove(item);
    }

    private async Task HandleScheduleSubmit()
    {
        if (currentTotalNewSchedules > selectedRemainingAmount || !newSchedulesList.Any())
            return;

        isLoading = true;

        var dto = new CreateSchedulesDto
        {
            FeeId = selectedFeeId,
            Schedules = newSchedulesList.Select(x => new ScheduleItemDto
            {
                Amount = x.Amount,
                DueDate = x.DueDate
            }).ToList()
        };

        var success = await FinancialsService.SaveSchedulesAsync(dto);

        if (success)
        {
            showScheduleModal = false;
            newSchedulesList.Clear();

            await LoadDashboardStats(); 
            await LoadFees();           

        }
        else
        {
            Console.WriteLine("ð‘· «·ÕðŸ:  √þœ „‰ √‰ «·„»«·€ ·«   Ã«Ê“ «·≈Ã„«·Ì.");
        }

        isLoading = false; 
    }
    private async Task LoadFees()
    {
        isLoading = true;
        var result = await FinancialsService.GetPagedFeesAsync(searchTerm, currentPage);
        fees = result.Items;
        hasNextPage = result.HasNextPage;
        hasPreviousPage = result.HasPreviousPage;
        totalPages = result.TotalPages;
        isLoading = false;
    }
    private async Task OnSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        currentPage = 1; 
        await LoadFees();
    }
    private async Task ChangePage(int newPage)
    {
        currentPage = newPage;
        await LoadFees(); 
    }
    private string GetStatusClass(string status) => status switch
    {
        "„þ „·…" => "bg-success",
        "„ √Œ—…" => "bg-danger",
        " Õ  «· Õ’Ì·" => "bg-warning text-dark",
        _ => "bg-secondary"
    };
    private async Task LoadDashboardStats()
    {
        try
        {
            isLoading = true;
            stats = await FinancialsService.GetDashboardStatsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading stats: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
   
}


