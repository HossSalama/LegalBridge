@code {
    private IEnumerable<smartLaywer.Models.LegalLibrary> documents = new List<smartLaywer.Models.LegalLibrary>();
    private string searchTerm = "";
    private smartLaywer.Models.LegalLibrary newDoc = new();
    private IBrowserFile? selectedFile;
    private bool isModalOpen = false; 

    private void OpenModal() { newDoc = new(); isModalOpen = true; }
    private void CloseModal() => isModalOpen = false;
    protected override async Task OnInitializedAsync()
    {
        await LoadDocuments();
    }

    private async Task LoadDocuments()
    {
        documents = await LegalService.GetAllDocumentsAsync();
    }
    private void OnFileChange(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
    }

    private async Task HandleAddDocument()
    {
        if (selectedFile == null) return;

        newDoc.AddedBy = 1;
        newDoc.AddedByNavigation = null!;

        newDoc.MimeType = "pen";
        newDoc.FilePath = "pending";

        var success = await LegalService.AddDocumentAsync(selectedFile, newDoc);
        if (success)
        {
            await LoadDocuments(); 
            CloseModal();
            selectedFile = null;
        }
    }


    private async Task HandleOpenFile(string path)
    {
        var fullPath = LegalService.GetFullPath(path);
        if (File.Exists(fullPath))
        {
            await Launcher.Default.OpenAsync(new OpenFileRequest
            {
                File = new ReadOnlyFile(fullPath)
            });
        }
        else
        {
            await App.Current.MainPage.DisplayAlert(" ‰»ÌÂ", "«·„·ð €Ì— „ÊÃÊœ ðÌ «·„”«— «·„Õœœ", "„Ê«ðÞ");
        }
    }

    private const string IconScale = """<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="3" x2="12" y2="21"/><path d="M3 9l9-7 9 7"/><path d="M3 9l4.5 9 4.5-9"/><path d="M12 9l4.5 9 4.5-9"/></svg>""";
    private const string IconFile = """<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>""";
    private const string IconBook = """<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>""";

    // Ê √þœ ≈‰ „ÌÀÊœ GetIcon » ” Œœ„Â„ ’Õ:
    private string GetIcon(string mimeType)
    {
        if (string.IsNullOrEmpty(mimeType)) return IconFile;

        if (mimeType.Contains("pdf")) return IconFile;
        if (mimeType.Contains("word") || mimeType.Contains("officedocument")) return IconBook;

        return IconFile;
    }
    // „ÌÀÊœ „”«⁄œ… ··Ð CSS Class » «⁄ «·Ð Badge
    private string GetBadgeClass(LibraryCategoryEnum category) => category switch
    {
        LibraryCategoryEnum.Civil => "badge-blue",
        LibraryCategoryEnum.Criminal => "badge-red",
        LibraryCategoryEnum.PersonalStatus => "badge-amber",
        LibraryCategoryEnum.Commercial => "badge-purple",
        _ => "badge-green"
    };
}
