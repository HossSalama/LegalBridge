@page "/financials/client-profile/{ClientId:int}"
@inject IFinancialsService FinancialsService
@inject NavigationManager Navigation

<div class="page-wrapper" dir="rtl">
    @if (profile == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Ã«—Ì  Õ„Ì· „·ð «·⁄„Ì· «·„«·Ì...</p>
        </div>
    }
    else
    {
        <div class="page-header">
            <div>
                <h2 class="page-title">«·„·ð «·„«·Ì: @profile.ClientName</h2>
                <p class="page-sub">þ‘ð Õ”«» «·⁄„Ì· / „ «»⁄… «·œð⁄« </p>
            </div>
            <button class="btn-pdf" @onclick="ExportToPdf">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                    <polyline points="14 2 14 8 20 8" />
                </svg>
                 ’œÌ— (PDF)
            </button>
        </div>

        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-icon green">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="1" x2="12" y2="23" />
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                    </svg>
                </div>
                <div>
                    <p class="stat-label">≈Ã„«·Ì «·„Õ’·</p>
                    <h3 class="stat-value green">@profile.TotalPaid.ToString("N0") Ã.„</h3>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon amber">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <polyline points="12 6 12 12 16 14" />
                    </svg>
                </div>
                <div>
                    <p class="stat-label">«·„»«·€ «·„” ÕÞ…</p>
                    <h3 class="stat-value amber">@profile.TotalAgreedAmount.ToString("N0") Ã.„</h3>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon red">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                        <line x1="12" y1="9" x2="12" y2="13" />
                        <line x1="12" y1="17" x2="12.01" y2="17" />
                    </svg>
                </div>
                <div>
                    <p class="stat-label">„ √Œ—…</p>
                    <h3 class="stat-value red">@profile.TotalOverdue.ToString("N0") Ã.„</h3>
                </div>
            </div>
        </div>

        @foreach (var caseItem in profile.Cases)
        {
            var paidPercent = caseItem.CaseTotalFee > 0
            ? (int)((caseItem.Transactions.Where(t => t.Type == "Credit").Sum(t => t.Amount) / caseItem.CaseTotalFee) * 100)
            : 0;
            var paidAmount = caseItem.Transactions.Where(t => t.Type == "Credit").Sum(t => t.Amount);

            <div class="case-card">
                <div class="case-header">
                    <div>
                        <span class="badge-done">„þ „·…</span>
                        <h5 class="case-num">«·Þ÷Ì…: @caseItem.CaseNumber</h5>
                        <p class="case-dates">«·»œ«Ì…: @DateTime.Now.ToShortDateString() &nbsp;|&nbsp; «·«” ÕÞ«Þ: 13-07-2027</p>
                    </div>
                    <div class="case-total">≈Ã„«·Ì «·√ ⁄«»: @caseItem.CaseTotalFee.ToString("N0") Ã.„</div>
                </div>

                <div class="case-body">
                    <div class="progress-wrap">
                        <div class="progress-top">
                            <span> Þœ„ «·”œ«œ</span>
                            <span class="progress-pct">@paidPercent%</span>
                        </div>
                        <div class="progress-bar-bg">
                            <div class="progress-bar-fill" style="width: @paidPercent%"></div>
                        </div>
                        <div class="progress-bottom">
                            «·„œðÊ⁄: @paidAmount.ToString("N0") / @caseItem.CaseTotalFee.ToString("N0")
                            @if (paidPercent >= 100)
                            {
                                <span class="text-complete">&nbsp;| „þ „·</span>
                            }
                        </div>
                    </div>

                    <div class="two-col">
                        <div>
                            <p class="col-title">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10" />
                                    <polyline points="12 6 12 12 16 14" />
                                </svg>
                                ”Ã· «·œð⁄«  (@caseItem.Transactions.Count)
                            </p>
                            <div class="trans-table">
                                <table>
                                    <thead>
                                        <tr>
                                            <th>«· «—ÌŒ</th>
                                            <th>«·»Ì«‰</th>
                                            <th>«·„»·€</th>
                                            <th>«·‰Ê⁄</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var trans in caseItem.Transactions)
                                        {
                                            <tr>
                                                <td class="muted">@trans.Date.ToShortDateString()</td>
                                                <td>@trans.Description</td>
                                                <td class="@(trans.Type == "Credit" ? "credit" : "debit")">
                                                    @(trans.Type == "Credit" ? "+" : "-") @trans.Amount.ToString("N0")
                                                </td>
                                                <td>
                                                    <span class="@(trans.Type == "Credit" ? "badge-credit" : "badge-debit")">
                                                        @(trans.Type == "Credit" ? " Õ’Ì·" : "„’«—Ìð")
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div>
                            <p class="col-title">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                                    <line x1="16" y1="2" x2="16" y2="6" />
                                    <line x1="8" y1="2" x2="8" y2="6" />
                                    <line x1="3" y1="10" x2="21" y2="10" />
                                </svg>
                                ÃœÊ· «·√Þ”«ÿ
                            </p>
                            <div class="install-list">
                                @foreach (var installment in caseItem.Installments)
                                {
                                    <div class="install-row">
                                        <div>
                                            <p class="install-num">Þ”ÿ #@installment.InstallmentNumber</p>
                                            <p class="install-date">@installment.DueDate.ToShortDateString()</p>
                                        </div>
                                        <div class="install-right">
                                            <p class="install-amt">@installment.Amount.ToString("N0") Ã.„</p>
                                            <span class="@(installment.Status == "Paid" ? "badge-paid" : "badge-pend")">
                                                @(installment.Status == "Paid" ? "Paid" : "Pending")
                                            </span>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="footer-bar">
            <button class="btn-back" @onclick="GoBack">
                «·⁄Êœ… ··—∆Ì”Ì…
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                </svg>
            </button>
        </div>
    }
</div>

<style>
    .page-wrapper {
        padding: 1.5rem;
        background: #f8f9fa;
        min-height: 100vh;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1.5rem;
    }

    .page-title {
        font-size: 22px;
        font-weight: 500;
        color: #1e293b;
        margin: 0;
    }

    .page-sub {
        font-size: 13px;
        color: #64748b;
        margin: 4px 0 0;
    }

    .btn-pdf {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        border-radius: 8px;
        border: 1px solid #dee2e6;
        background: #fff;
        font-size: 13px;
        color: #1e293b;
        cursor: pointer;
    }

        .btn-pdf:hover {
            background: #f1f5f9;
        }

    /* Stats */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr); /* þ«‰ 4 Œ·ÌÂ 3 */
        gap: 12px;
        margin-bottom: 1.5rem;
    }
    .stat-card {
        background: #fff;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 12px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 1px 4px rgba(0,0,0,.05);
    }

    .stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .stat-icon svg {
            width: 20px;
            height: 20px;
        }

        .stat-icon.green {
            background: #EAF3DE;
            color: #3B6D11;
        }

        .stat-icon.blue {
            background: #E6F1FB;
            color: #185FA5;
        }

        .stat-icon.amber {
            background: #FAEEDA;
            color: #854F0B;
        }

        .stat-icon.red {
            background: #FCEBEB;
            color: #A32D2D;
        }

    .stat-label {
        font-size: 12px;
        color: #64748b;
        margin: 0 0 4px;
    }

    .stat-value {
        font-size: 20px;
        font-weight: 500;
        margin: 0;
    }

        .stat-value.green {
            color: #3B6D11;
        }

        .stat-value.blue {
            color: #185FA5;
        }

        .stat-value.amber {
            color: #BA7517;
        }

        .stat-value.red {
            color: #A32D2D;
        }

    /* Case Card */
    .case-card {
        background: #fff;
        border-radius: 12px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 1px 4px rgba(0,0,0,.05);
        overflow: hidden;
        margin-bottom: 1rem;
    }

    .case-header {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .badge-done {
        background: #EAF3DE;
        color: #3B6D11;
        font-size: 11px;
        padding: 3px 10px;
        border-radius: 20px;
        display: inline-block;
        margin-bottom: 6px;
    }

    .case-num {
        font-size: 15px;
        font-weight: 500;
        color: #1e293b;
        margin: 0;
    }

    .case-dates {
        font-size: 12px;
        color: #64748b;
        margin: 3px 0 0;
    }

    .case-total {
        font-size: 16px;
        font-weight: 500;
        color: #BA7517;
    }

    .case-body {
        padding: 1.25rem;
        background: #f8f9fa;
    }

    /* Progress */
    .progress-wrap {
        margin-bottom: 1.25rem;
    }

    .progress-top {
        display: flex;
        justify-content: space-between;
        font-size: 12px;
        color: #64748b;
        margin-bottom: 6px;
    }

    .progress-pct {
        font-weight: 500;
        color: #3B6D11;
    }

    .progress-bar-bg {
        height: 8px;
        background: #e2e8f0;
        border-radius: 20px;
        overflow: hidden;
    }

    .progress-bar-fill {
        height: 100%;
        background: #EF9F27;
        border-radius: 20px;
        transition: width 0.8s ease;
    }

    .progress-bottom {
        font-size: 12px;
        color: #64748b;
        margin-top: 5px;
    }

    .text-complete {
        color: #3B6D11;
    }

    /* Two Col */
    .two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .col-title {
        font-size: 13px;
        font-weight: 500;
        color: #64748b;
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 10px;
    }

        .col-title svg {
            width: 14px;
            height: 14px;
        }

    /* Transactions Table */
    .trans-table {
        background: #fff;
        border-radius: 10px;
        border: 1px solid #f1f5f9;
        overflow: hidden;
    }

        .trans-table table {
            width: 100%;
            font-size: 13px;
            border-collapse: collapse;
        }

        .trans-table thead th {
            padding: 8px 12px;
            background: #f8f9fa;
            color: #64748b;
            font-weight: 500;
            font-size: 12px;
            text-align: right;
        }

        .trans-table tbody td {
            padding: 9px 12px;
            border-top: 1px solid #f1f5f9;
            color: #1e293b;
        }

            .trans-table tbody td.muted {
                color: #64748b;
            }

    .badge-credit {
        background: #EAF3DE;
        color: #3B6D11;
        font-size: 11px;
        padding: 2px 10px;
        border-radius: 20px;
    }

    .badge-debit {
        background: #FCEBEB;
        color: #A32D2D;
        font-size: 11px;
        padding: 2px 10px;
        border-radius: 20px;
    }

    .credit {
        color: #3B6D11;
        font-weight: 500;
    }

    .debit {
        color: #A32D2D;
        font-weight: 500;
    }

    /* Installments */
    .install-list {
        background: #fff;
        border-radius: 10px;
        border: 1px solid #f1f5f9;
        overflow: hidden;
    }

    .install-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 14px;
        border-bottom: 1px dashed #e2e8f0;
    }

        .install-row:last-child {
            border-bottom: none;
        }

    .install-num {
        font-size: 13px;
        font-weight: 500;
        color: #1e293b;
        margin: 0;
    }

    .install-date {
        font-size: 12px;
        color: #64748b;
        margin: 2px 0 0;
    }

    .install-right {
        text-align: left;
    }

    .install-amt {
        font-size: 13px;
        font-weight: 500;
        color: #1e293b;
        margin: 0 0 4px;
    }

    .badge-paid {
        background: #EAF3DE;
        color: #3B6D11;
        font-size: 11px;
        padding: 2px 10px;
        border-radius: 20px;
        display: inline-block;
    }

    .badge-pend {
        background: #FAEEDA;
        color: #854F0B;
        font-size: 11px;
        padding: 2px 10px;
        border-radius: 20px;
        display: inline-block;
    }

    /* Footer */
    .footer-bar {
        display: flex;
        justify-content: flex-end;
        margin-top: 1.5rem;
    }

    .btn-back {
        padding: 10px 28px;
        border-radius: 30px;
        background: #2C2C2A;
        color: #F1EFE8;
        font-size: 14px;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .btn-back:hover {
            background: #444441;
        }

    @@media (max-width: 768px) {
        .stats-row {
            grid-template-columns: repeat(2, 1fr);
        }

        .two-col {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    [Parameter] public int ClientId { get; set; }
    private ClientFinancialProfileDto? profile;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            profile = await FinancialsService.GetClientFullFinancialHistoryAsync(ClientId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    private void GoBack() => Navigation.NavigateTo("/fees");
    private void ExportToPdf() => Console.WriteLine("Exporting PDF...");
}