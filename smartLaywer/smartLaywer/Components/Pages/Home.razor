    .modal-footer {
        display: flex;
        justify-content: flex-end;
    }
</style>

@code {
    private record StatCard(string Title, string Value, string Trend, string IconClass, string Icon);
    private record HearingItem(string Case, string Client, string Date, string Time, string Court, string Status);
    private record MonthItem(string Month, int Cases);
    private record StatusItem(string Name, int Value, string Color);

    private HearingItem? selectedHearing;

    private List<StatCard> stats = new()
    {
        new("إجمالي القضايا",     "147", "+12%", "stat-icon bg-blue",  IconBriefcase),
        new("العملاء النشطين",    "89",  "+8%",  "stat-icon bg-green", IconUsers),
        new("جلسات هذا الأسبوع", "23",  "+5",   "stat-icon bg-amber", IconCalendar),
        new("تنبيهات عاجلة",      "7",   "عاجل", "stat-icon bg-red",   IconAlert),
    };

    private List<HearingItem> upcomingHearings = new()
    {
        new("قضية رقم 2024/156", "أحمد محمود", "2026-04-01", "10:00 ص", "محكمة القاهرة الابتدائية", "pending"),
        new("قضية رقم 2024/142", "سارة علي",   "2026-04-02", "11:30 ص", "محكمة الجيزة الابتدائية",  "pending"),
        new("قضية رقم 2024/189", "محمد حسن",   "2026-04-03", "09:00 ص", "محكمة الاستئناف",           "urgent"),
    };

    private List<MonthItem> monthlyData = new()
    {
        new("يناير", 12), new("فبراير", 15), new("مارس", 18), new("أبريل", 8),
    };

    private List<StatusItem> caseStatusData = new()
    {
        new("جارية",  87, "#3b82f6"),
        new("مكتملة", 45, "#10b981"),
        new("معلقة",  15, "#f59e0b"),
    };

    private void ShowDetails(HearingItem h) => selectedHearing = h;
    private void CloseDetails() => selectedHearing = null;

    private const string IconBriefcase = """<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>""";
    private const string IconUsers = """<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>""";
    private const string IconCalendar = """<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>""";
    private const string IconAlert = """<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>""";
}
