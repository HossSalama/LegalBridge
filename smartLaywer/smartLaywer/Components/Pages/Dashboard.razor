@page "/"
@page "/dashboard"
@inject IJSRuntime JSRuntime

<div class="space-y-6 p-2 lg:p-6 bg-slate-50 min-h-screen" dir="rtl">
    @* Page Header *@
    <div>
        <h1 class="text-3xl font-bold text-slate-900">لوحة التحكم</h1>
        <p class="text-slate-600 mt-1">نظرة عامة على جميع الأنشطة والإحصائيات</p>
    </div>

    @* Stats Grid *@
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        @* كرت إجمالي القضايا *@
        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-sm text-slate-600">إجمالي القضايا</p>
                <h3 class="text-3xl font-bold mt-2">147</h3>
                <p class="text-sm text-green-600 mt-1 flex items-center gap-1">
                    <i data-lucide="trending-up" class="h-3 w-3"></i>
                    +12%
                </p>
            </div>
            <div class="bg-blue-600 h-12 w-12 rounded-lg flex items-center justify-center">
                <i data-lucide="briefcase" class="h-6 w-6 text-white"></i>
            </div>
        </div>

        @* كرت العملاء *@
        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-sm text-slate-600">العملاء النشطين</p>
                <h3 class="text-3xl font-bold mt-2">89</h3>
                <p class="text-sm text-green-600 mt-1 flex items-center gap-1">
                    <i data-lucide="trending-up" class="h-3 w-3"></i>
                    +8%
                </p>
            </div>
            <div class="bg-green-600 h-12 w-12 rounded-lg flex items-center justify-center">
                <i data-lucide="users" class="h-6 w-6 text-white"></i>
            </div>
        </div>

        @* كرت الجلسات *@
        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-sm text-slate-600">جلسات هذا الأسبوع</p>
                <h3 class="text-3xl font-bold mt-2">23</h3>
                <p class="text-sm text-green-600 mt-1 flex items-center gap-1">
                    <i data-lucide="trending-up" class="h-3 w-3"></i>
                    +5
                </p>
            </div>
            <div class="bg-amber-600 h-12 w-12 rounded-lg flex items-center justify-center">
                <i data-lucide="calendar" class="h-6 w-6 text-white"></i>
            </div>
        </div>

        @* كرت التنبيهات *@
        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-sm text-slate-600">تنبيهات عاجلة</p>
                <h3 class="text-3xl font-bold mt-2">7</h3>
                <p class="text-sm text-red-600 mt-1 flex items-center gap-1 italic font-bold">
                    عاجل
                </p>
            </div>
            <div class="bg-red-600 h-12 w-12 rounded-lg flex items-center justify-center">
                <i data-lucide="alert-circle" class="h-6 w-6 text-white"></i>
            </div>
        </div>
    </div>

    @* Charts Row *@
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        @* Monthly Cases Chart *@
        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
            <h3 class="font-bold text-slate-800 mb-4 text-lg underline decoration-amber-500">القضايا الشهرية</h3>
            <div class="h-[250px] flex items-center justify-center bg-slate-50 border-dashed border-2 border-slate-200 rounded-lg">
                <p class="text-slate-400">[هنا سيتم ربط الرسم البياني للأعمدة]</p>
            </div>
        </div>

        @* Case Status Pie Chart *@
        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
            <h3 class="font-bold text-slate-800 mb-4 text-lg underline decoration-blue-500">حالة القضايا</h3>
            <div class="h-[250px] flex items-center justify-center bg-slate-50 border-dashed border-2 border-slate-200 rounded-lg">
                <p class="text-slate-400">[هنا سيتم ربط الرسم البياني الدائري]</p>
            </div>
        </div>
    </div>

    @* Upcoming Hearings (Table) *@
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
            <h3 class="font-bold text-slate-800">الجلسات القادمة</h3>
            <button class="text-sm font-medium text-amber-600 hover:text-amber-700">عرض الكل</button>
        </div>
        <div class="p-6 overflow-x-auto">
            <table class="w-full text-right border-collapse">
                <thead>
                    <tr class="text-slate-500 text-sm border-b border-slate-100">
                        <th class="pb-4 font-bold">القضية</th>
                        <th class="pb-4 font-bold">العميل</th>
                        <th class="pb-4 font-bold">التاريخ والوقت</th>
                        <th class="pb-4 font-bold">المحكمة</th>
                        <th class="pb-4 text-center font-bold">الحالة</th>
                        <th class="pb-4 text-center font-bold">العمليات</th>
                    </tr>
                </thead>
                <tbody>
                    @* البيانات سيتم جلبها من الـ Database هنا لاحقاً *@
                    <tr class="border-b border-slate-50 hover:bg-slate-50/80 transition-colors">
                        <td class="py-4">
                            <div class="flex flex-col">
                                <span class="font-bold text-slate-900 text-sm">قضية رقم 2024/156</span>
                            </div>
                        </td>
                        <td class="py-4 text-sm text-slate-600 font-medium italic">أحمد محمود</td>
                        <td class="py-4">
                            <div class="flex flex-col">
                                <span class="text-sm font-bold">2026-04-01</span>
                                <span class="text-xs text-slate-500 flex items-center gap-1">
                                    <i data-lucide="clock" class="h-3 w-3"></i> 10:00 ص
                                </span>
                            </div>
                        </td>
                        <td class="py-4 text-sm text-slate-500">محكمة القاهرة الابتدائية</td>
                        <td class="py-4 text-center">
                            <span class="bg-amber-100 text-amber-700 px-3 py-1 rounded-full text-xs font-bold">قيد الانتظار</span>
                        </td>
                        <td class="py-4 text-center">
                            <button class="bg-white border border-slate-200 px-3 py-1 rounded text-xs hover:bg-slate-50">التفاصيل</button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    @* Quick Actions Row *@
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 pb-6">
        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm hover:shadow-md transition-all cursor-pointer group">
            <div class="flex items-center gap-4">
                <div class="h-12 w-12 rounded-lg bg-blue-100 flex items-center justify-center group-hover:bg-blue-600 transition-colors">
                    <i data-lucide="briefcase" class="h-6 w-6 text-blue-600 group-hover:text-white"></i>
                </div>
                <div>
                    <h4 class="font-bold text-slate-800">إضافة قضية جديدة</h4>
                    <p class="text-sm text-slate-500">ابدأ تسجيل ملف جديد</p>
                </div>
            </div>
        </div>

        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm hover:shadow-md transition-all cursor-pointer group">
            <div class="flex items-center gap-4">
                <div class="h-12 w-12 rounded-lg bg-green-100 flex items-center justify-center group-hover:bg-green-600 transition-colors">
                    <i data-lucide="users" class="h-6 w-6 text-green-600 group-hover:text-white"></i>
                </div>
                <div>
                    <h4 class="font-bold text-slate-800">إضافة عميل جديد</h4>
                    <p class="text-sm text-slate-500">تسجيل بيانات موكل جديد</p>
                </div>
            </div>
        </div>

        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm hover:shadow-md transition-all cursor-pointer group">
            <div class="flex items-center gap-4">
                <div class="h-12 w-12 rounded-lg bg-amber-100 flex items-center justify-center group-hover:bg-amber-600 transition-colors">
                    <i data-lucide="calendar" class="h-6 w-6 text-amber-600 group-hover:text-white"></i>
                </div>
                <div>
                    <h4 class="font-bold text-slate-800">جدولة جلسة</h4>
                    <p class="text-sm text-slate-500">حدد موعد جلسة جديد</p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JSRuntime.InvokeVoidAsync("initializeIcons");
    }
}