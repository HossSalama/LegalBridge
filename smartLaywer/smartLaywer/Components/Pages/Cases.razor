@code {
    // ── Data
    private List<CaseSummaryDto> allCases = new();
    private List<CaseSummaryDto> filteredCases = new();
    private CaseStatsDto? stats;

    // Lookups
    private List<Client> existingClients = new();
    private List<CaseType> caseTypes = new();
    private List<CaseStatus> caseStatuses = new();
    private List<Court> courts = new();
    private List<User> lawyers = new();

    // ── UI State
    private bool isLoading = true;
    private bool isSaving = false;

    // Separate error states
    private string loadErrorMsg = string.Empty;
    private string addErrorMsg = string.Empty;
    private string editErrorMsg = string.Empty;
    private string modalErrorMsg = string.Empty;

    // Filter
    private string searchTerm = string.Empty;
    private string statusFilter = string.Empty;

    // Add modal
    private bool showAddModal = false;
    private bool isNewClient = false;
    private Case newCase = new();
    private Client newClient = new();

    // Details modal
    private bool showDetailsModal = false;
    private Case? selectedCase;

    // Edit modal
    private bool showEditModal = false;
    private CaseEditDto? editDto;

    // Fee for the new case
    private decimal newCaseFeeAmount = 0;
    private string newCaseFeeNotes = string.Empty;
    private DateTime newCaseFeeDueDate = DateTime.Today.AddMonths(1);

    // ── Lifecycle
    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    // ── Data Loading
    private async Task LoadDataAsync()
    {
        isLoading = true;
        loadErrorMsg = string.Empty;
        StateHasChanged();
        try
        {
            // Lookups first so dropdowns are ready
            await LoadLookupsAsync();

            // Then cases & stats (sequential — same DbContext)
            allCases = await CaseService.GetAllCasesAsync();
            stats = await CaseService.GetCaseStatsAsync();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            loadErrorMsg = $"حدث خطأ أثناء تحميل البيانات: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadLookupsAsync()
    {
        // Sequential — EF Core DbContext is NOT thread-safe.
        // Task.WhenAll on the same scoped context causes:
        // "A second operation was started on this context before a previous operation completed."
        existingClients = await LookupService.GetActiveClientsAsync();
        caseTypes = await LookupService.GetCaseTypesAsync();
        caseStatuses = await LookupService.GetCaseStatusesAsync();
        courts = await LookupService.GetCourtsAsync();
        lawyers = await LookupService.GetActiveLawyersAsync();
    }

    // ── Filter / Search
    private void OnSearchChanged(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        filteredCases = allCases.Where(c =>
        {
            bool matchSearch = string.IsNullOrWhiteSpace(searchTerm) ||
                (c.CaseNumber?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (c.Title?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (c.ClientName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false);

            bool matchStatus = string.IsNullOrEmpty(statusFilter) ||
                (c.Status?.Equals(statusFilter, StringComparison.OrdinalIgnoreCase) ?? false);

            return matchSearch && matchStatus;
        }).ToList();
    }

    // ── Add Modal
    private void OpenAddModal()
    {
        newCase = new Case { OpenDate = DateTime.Today };
        newClient = new Client { ClientType = ClientTypeEnum.Individual };
        isNewClient = false;
        addErrorMsg = string.Empty;
        newCaseFeeAmount = 0;
        newCaseFeeNotes = string.Empty;
        newCaseFeeDueDate = DateTime.Today.AddMonths(1);
        showAddModal = true;
        showAddModal = true;
    }

    private void CloseAddModal()
    {
        showAddModal = false;
        addErrorMsg = string.Empty;
    }

    private async Task SaveNewCase()
    {
        addErrorMsg = string.Empty;

        // Validate case
        if (string.IsNullOrWhiteSpace(newCase.CaseNumber)) { addErrorMsg = "رقم القضية مطلوب."; return; }
        if (string.IsNullOrWhiteSpace(newCase.Title)) { addErrorMsg = "عنوان القضية مطلوب."; return; }
        if (newCase.CaseTypeId == 0) { addErrorMsg = "نوع القضية مطلوب."; return; }
        if (newCase.StatusId == 0) { addErrorMsg = "حالة القضية مطلوبة."; return; }
        if (newCase.CourtId == 0) { addErrorMsg = "المحكمة مطلوبة."; return; }
        if (newCase.AssignedLawyerId == 0) { addErrorMsg = "المحامي المسؤول مطلوب."; return; }
        if (isNewClient)
        {
            if (newClient.ClientType == ClientTypeEnum.Individual &&
                string.IsNullOrWhiteSpace(newClient.NationalId))
            {
                addErrorMsg = "الرقم القومي مطلوب للأفراد.";
                return;
            }
            if (newClient.ClientType != ClientTypeEnum.Individual &&
                string.IsNullOrWhiteSpace(newClient.CommercialReg))
            {
                addErrorMsg = "رقم التسجيل التجاري مطلوب للشركات والجهات.";
                return;
            }
        }

        isSaving = true;
        try
        {
            if (isNewClient)
            {
                if (string.IsNullOrWhiteSpace(newClient.FullName)) { addErrorMsg = "اسم العميل مطلوب."; isSaving = false; return; }
                if (string.IsNullOrWhiteSpace(newClient.Phone)) { addErrorMsg = "رقم الهاتف مطلوب."; isSaving = false; return; }
                if (string.IsNullOrWhiteSpace(newClient.Address)) { addErrorMsg = "العنوان مطلوب."; isSaving = false; return; }

                newClient.NationalId = string.IsNullOrWhiteSpace(newClient.NationalId) ? null : newClient.NationalId.Trim();
                newClient.CommercialReg = string.IsNullOrWhiteSpace(newClient.CommercialReg) ? null : newClient.CommercialReg.Trim();
                newClient.Email = string.IsNullOrWhiteSpace(newClient.Email) ? null : newClient.Email.Trim();
                newClient.SecondaryPhone = string.IsNullOrWhiteSpace(newClient.SecondaryPhone) ? null : newClient.SecondaryPhone.Trim();
                newClient.JobTitle = string.IsNullOrWhiteSpace(newClient.JobTitle) ? null : newClient.JobTitle.Trim();
                newClient.Gender = string.IsNullOrWhiteSpace(newClient.Gender) ? null : newClient.Gender.Trim();

                newClient.Phone = newClient.Phone.Trim();

                await CaseService.ValidateClientIdentifierUniquenessAsync(newClient);
                var saved = await ClientService.AddClientAsync(newClient);
                newCase.ClientId = saved.Id;
            }
            else
            {
                if (newCase.ClientId == 0) { addErrorMsg = "يجب اختيار عميل."; isSaving = false; return; }
            }

            Fee? feeToSave = null;
            if (newCaseFeeAmount > 0)
            {
                feeToSave = new Fee
                {
                    TotalAmount = newCaseFeeAmount,
                    DueDate = newCaseFeeDueDate,
                    Notes = string.IsNullOrWhiteSpace(newCaseFeeNotes) ? null : newCaseFeeNotes.Trim(),
                    CreatedBy = newCase.AssignedLawyerId   
                };
            }

            await CaseService.AddCaseAsync(newCase, feeToSave);
            CloseAddModal();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            addErrorMsg = $"فشل الحفظ: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    // ── Details Modal
    private async Task OpenDetailsModal(int caseId)
    {
        selectedCase = null;
        showDetailsModal = true;
        StateHasChanged();
        try
        {
            selectedCase = await CaseService.GetCaseWithDetailsAsync(caseId);
        }
        catch (Exception ex)
        {
            modalErrorMsg = $"فشل تحميل التفاصيل: {ex.Message}";
            showDetailsModal = false;
        }
    }

    // ── Edit Modal
    private async Task OpenEditModal(int caseId)
    {
        editErrorMsg = string.Empty;
        try
        {
            var c = await CaseService.GetCaseWithDetailsAsync(caseId);
            if (c == null) return;

            editDto = new CaseEditDto
            {
                Id = c.Id,
                Title = c.Title,
                StatusId = c.StatusId,
                CourtId = c.CourtId,
                DeptId = c.DeptId,
                AssignedLawyerId = c.AssignedLawyerId,
                Stage = c.Stage,
                CloseDate = c.CloseDate,
                ArchiveNote = c.ArchiveNote
            };
            showEditModal = true;
        }
        catch (Exception ex)
        {
            modalErrorMsg = $"فشل تحميل بيانات التعديل: {ex.Message}";
        }
    }

    private void CloseEditModal()
    {
        showEditModal = false;
        editDto = null;
        editErrorMsg = string.Empty;
    }

    private async Task SaveEditCase()
    {
        if (editDto == null) return;
        editErrorMsg = string.Empty;

        if (string.IsNullOrWhiteSpace(editDto.Title)) { editErrorMsg = "عنوان القضية مطلوب."; return; }
        if (editDto.StatusId == 0) { editErrorMsg = "الحالة مطلوبة."; return; }
        if (editDto.CourtId == 0) { editErrorMsg = "المحكمة مطلوبة."; return; }
        if (editDto.AssignedLawyerId == 0) { editErrorMsg = "المحامي مطلوب."; return; }

        isSaving = true;
        try
        {
            await CaseService.UpdateCaseAsync(editDto);
            CloseEditModal();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            editErrorMsg = $"فشل الحفظ: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    // ── Helpers 
    private static string GetStatusBadgeClass(string? status) => status switch
