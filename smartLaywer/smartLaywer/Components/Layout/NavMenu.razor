@inject NavigationManager Navigation

<div className="flex flex-col h-full text-white" dir="rtl">
    <div className="p-6">
        <div className="flex items-center gap-3 mb-8">
            <div className="h-10 w-10 rounded-lg bg-amber-600 flex items-center justify-center">
                <i data-lucide="scale" class="h-6 w-6 text-white"></i>
            </div>
            <div>
                <h1 className="font-bold text-lg">еогяи гАчжгМг</h1>
                <p className="text-xs text-slate-400">Legal System</p>
            </div>
        </div>

        <div className="space-y-1">
            <NavLink class="@GetActiveClass("/dashboard")" href="" Match="NavLinkMatch.All">
                <i data-lucide="layout-dashboard" class="h-5 w-5"></i>
                <span>АФми гАймъЦ</span>
            </NavLink>

            <NavLink class="@GetActiveClass("/clients")" href="clients">
                <i data-lucide="users" class="h-5 w-5"></i>
                <span>гАзЦАга</span>
            </NavLink>

            <NavLink class="@GetActiveClass("/cases")" href="cases">
                <i data-lucide="briefcase" class="h-5 w-5"></i>
                <span>гАчжгМг</span>
            </NavLink>

        </div>
    </div>
</div>

@code {
    private string GetActiveClass(string path)
    {
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
        bool isActive = (path == "/" && string.IsNullOrEmpty(relativePath)) || relativePath == path.TrimStart('/');

        return isActive
            ? "flex items-center gap-3 px-4 py-3 rounded-lg bg-amber-600 text-white transition-colors"
            : "flex items-center gap-3 px-4 py-3 rounded-lg text-slate-300 hover:bg-slate-800 hover:text-white transition-colors";
    }
}