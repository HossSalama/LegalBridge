@inherits LayoutComponentBase
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="app-shell" dir="rtl">

    <!-- ===== SIDEBAR (Desktop) ===== -->
    <aside class="sidebar @(sidebarOpen ? "sidebar-open" : "")">
        <!-- Logo -->
        <div class="sidebar-logo">
            <div class="logo-mark">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3l1.5 4.5H18l-3.75 2.75L15.75 15 12 12.25 8.25 15l1.5-4.75L6 7.5h4.5z"/>
                    <line x1="12" y1="15" x2="12" y2="21"/>
                    <line x1="8" y1="21" x2="16" y2="21"/>
                    <path d="M3 9l3 9M21 9l-3 9M3 9h18"/>
                </svg>
            </div>
            <div class="logo-text">
                <span class="logo-title">إدارة القضايا</span>
                <span class="logo-sub">Legal System</span>
            </div>
        </div>

        <!-- Nav -->
        <nav class="sidebar-nav">
            @foreach (var item in navItems)
            {
                <NavLink href="@item.Path" class="nav-item" ActiveClass="nav-item-active" Match="@item.Match">
                    <span class="nav-icon">@((MarkupString)item.Icon)</span>
                    <span class="nav-label">@item.Label</span>
                </NavLink>
            }
        </nav>
    </aside>

    <!-- Mobile overlay -->
    @if (sidebarOpen)
    {
        <div class="sidebar-overlay" @onclick="CloseSidebar"></div>
    }

    <!-- ===== MAIN CONTENT ===== -->
    <div class="main-wrap">

        <!-- Header -->
        <header class="app-header">
            <!-- Hamburger (mobile) -->
            <button class="hamburger" @onclick="ToggleSidebar">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="3" y1="12" x2="21" y2="12"/>
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <line x1="3" y1="18" x2="21" y2="18"/>
                </svg>
            </button>

            <div class="header-greeting">
                <span>مرحباً، </span>
                <strong>@userName</strong>
            </div>

            <div class="header-actions">
                <!-- Notifications -->
                <NavLink href="/notifications" class="notif-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                    </svg>
                    @if (notificationCount > 0)
                    {
                        <span class="notif-badge">@notificationCount</span>
                    }
                </NavLink>

                <!-- User avatar + dropdown -->
                <div class="user-menu-wrap">
                    <button class="user-avatar" @onclick="ToggleUserMenu">
                        @userName.Substring(0, 1)
                    </button>

                    @if (userMenuOpen)
                    {
                        <div class="user-dropdown">
                            <div class="user-dropdown-name">@userName</div>
                            <hr class="user-dropdown-sep" />
                            <button class="user-dropdown-item logout-item" @onclick="HandleLogout">
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                                    <polyline points="16 17 21 12 16 7"/>
                                    <line x1="21" y1="12" x2="9" y2="12"/>
                                </svg>
                                تسجيل الخروج
                            </button>
                        </div>
                    }
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <main class="page-content">
            @Body
        </main>
    </div>
</div>

@code {
    private bool sidebarOpen = false;
    private bool userMenuOpen = false;
    private string userName = "المحامي";
    private int notificationCount = 5;

    private record NavItem(string Path, string Label, string Icon, NavLinkMatch Match = NavLinkMatch.Prefix);

    private List<NavItem> navItems = new()
    {
        new("/",             "لوحة التحكم",      IconDashboard,   NavLinkMatch.All),
        new("/clients",      "العملاء",           IconUsers),
        new("/cases",        "القضايا",           IconBriefcase),
        new("/hearings",     "الجلسات",           IconCalendar),
        new("/hearings-detailed", "مراحل الجلسات", IconClipboard),
        new("/investigation","التحقيقات",         IconSearch),
        new("/appeals",      "الاستئناف",         IconTrending),
        new("/power-of-attorney","التوكيلات",     IconSignature),
        new("/memos",        "المذكرات",          IconEdit),
        new("/documents",    "المستندات",         IconFile),
        new("/agenda",       "الأجندة القضائية",  IconCalendarDays),
        new("/fees",         "الأتعاب",           IconDollar),
        new("/legal-library","المكتبة القانونية", IconBook),
        new("/notifications","التنبيهات",         IconBell),
        new("/reports",      "التقارير",          IconChart),
    };

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthService.IsAuthenticatedAsync())
        {
            Navigation.NavigateTo("/login");
            return;
        }
        userName = await AuthService.GetUserNameAsync() ?? "المحامي";
    }

    private void ToggleSidebar() => sidebarOpen = !sidebarOpen;
    private void CloseSidebar() => sidebarOpen = false;
    private void ToggleUserMenu() => userMenuOpen = !userMenuOpen;

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }

    // ── SVG Icons ──────────────────────────────────────────────────
    private const string IconDashboard   = """<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>""";
    private const string IconUsers       = """<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>""";
    private const string IconBriefcase   = """<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>""";
    private const string IconCalendar    = """<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>""";
    private const string IconClipboard  = """<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/></svg>""";
    private const string IconSearch      = """<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>""";
    private const string IconTrending    = """<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>""";
    private const string IconSignature   = """<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 19.5v.5a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8.5L18 5.5"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>""";
    private const string IconEdit        = """<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>""";
    private const string IconFile        = """<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>""";
    private const string IconCalendarDays= """<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01"/></svg>""";
    private const string IconDollar      = """<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>""";
    private const string IconBook        = """<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>""";
    private const string IconBell        = """<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>""";
    private const string IconChart       = """<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>""";
}
